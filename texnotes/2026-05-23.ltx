\begin{lemma}
If $\Gamma \prov M : A$, then $\sem \Gamma \prov \sem M : \sem A(M^*)$.
\end{lemma}

\begin{proof}\ %
  \begin{itemize}
  \item[Case:] $M = x$. If $x :A \in \Gamma$, then $x' : \sem A(x) \in \sem \Gamma$,
and indeed $x^* = x$, so that's correct.
  \item[Case:] $M = \lambda y . M$.
We know
\[
\Gamma, y : B \prov M : C
\over
\Gamma \prov \lambda y . M :  (y : B) \to C
\]
and we want to show
\[\sem \Gamma \prov \sem {\lambda y . M} : \sem {(y : B) \to C}(\lambda y . M^*)\]
which is
\[\sem \Gamma \prov \sem {\lambda y . M} : (y : B^*)(y' : \sem B(y)) \to
\sem C((\lambda y . M^*)\ y)\]
which should be $\beta$-equivalent to
\[\sem \Gamma \prov \sem {\lambda y . M} : (y : B^*)(y' : \sem B(y)) \to
\sem C(M^*)\]
but $\sem {\lambda y . M} = \lambda y.\lambda y'. \sem M$ and
\[\sem \Gamma, y : B^*, y' : \sem B(y) \prov \sem {M} : \sem C(M^*)\]
by induction hypothesis, so we're good.
  \item[Case:] $M\ N$.
We have $\Gamma \prov M : (y : B) \to C$ and $\Gamma \prov N : B$.
By i.h. this means
\[\sem \Gamma \prov \sem {M} : (y : B^*)(y' : \sem B(y)) \to \sem C(M^*\ y)\]
\[\sem \Gamma \prov \sem {N} :  \sem B(N^*)\]
This lets us conclude
\[\sem \Gamma \prov \sem {M}\ N^*\ \sem N : [\sem N/y'][N^*/y] \sem C(M^*\ y)\]
by compatibility of translation with substitution,
\[\sem \Gamma \prov \sem {M\ N} : \sem{ [N/y]C}(M^*\ N^*)\]
  \end{itemize}
\cqed
\end{proof}


