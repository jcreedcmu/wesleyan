\section{Tiny Objects}

\subsection{Language}
\[\begin{tabular}{rccl}
 Simple Contexts&$\Gamma\simp$&$::=$&$\cdot \celse \Gamma\simp, x : A\simp$\\
 Simple Types&$A\simp$&$::=$&$\cdots  $\\
 Simple Terms&$M\simp$&$::=$&$\cdots  $\\
\end{tabular}\]

\[\begin{tabular}{rccl}
  Contexts&$\Gamma$&$::=$&$\cdot \celse \Gamma, x : A \celse \Gamma, x :: A\simp$\\
  Types&$A$&$::=$&$\cdots \celse H $\\
  Terms&$M$&$::=$&$\cdots \celse x \sem t $\\
\end{tabular}\]

\subsection{Judgments}
\[\begin{tabular}{rl}
  Simple Context Formation&$\prov \Gamma\simp \rctx$\\
  Simple Type Formation&$\Gamma\simp \prov A\simp : \rtype$\\
  Simple Term Typing&$\Gamma\simp \prov M\simp : A\simp$\\
  Context Formation&$\prov \Gamma \rctx$\\
  Type Formation&$\Gamma \prov A : \rtype$\\
  Term Typing&$\Gamma \prov M : A$\\
\end{tabular}\]

\subsection{Rules}

\subsubsection{Context Formation}
\[
\begin{prooftree}
\prov \Gamma \rctx \qquad \Gamma \prov A : \rtype
\justifies
\prov (\Gamma, x : A)\rctx
\end{prooftree}
\]
\[
\begin{prooftree}
\prov \Gamma \rctx \qquad \Gamma\erase \prov A\simp : \rtype
\justifies
\prov (\Gamma, x :: A\simp)\rctx
\end{prooftree}
\]
\subsubsection{Term Typing}
\[
\begin{prooftree}
\Gamma \prov t : H\qquad x :: A\simp \in \Gamma
\justifies
\Gamma \prov x\sem t : A\simp\hyd t \Gamma
\end{prooftree}
\]
\subsection{Operations}

\subsubsection{Erasure}
Takes a context, yields a simple context.
\[\begin{tabular}{rcl}
 $(\Gamma, x : A)\erase$&$:=$&$\Gamma\erase, x : A\erase $\\
 $(\Gamma, x :: A\simp)\erase$&$:=$&$\Gamma\erase, x : A\simp $\\
 $H\erase$&$:=$&$1 $\\
 $(x\sem t)\erase$&$:=$&$x $\\
\end{tabular}\]

\subsubsection{Lock}
Takes a simple context, yields a context.
\[\begin{tabular}{rcl}
 $(\Gamma\simp, x : A\simp)\locking$&$:=$&$\Gamma\simp\locking, x :: A\simp $\\
\end{tabular}\]

\subsubsection{Rehydrate}
Takes a simple expression in an erased context and a term of type $H$, and yields
an expression in the original context.

\[\begin{tabular}{rcp{5cm}}
$(M\ N)\hyd t \Gamma $&$:=$&$ (M\hyd t \Gamma)\ (N\hyd t \Gamma)$\\
$(\lambda x . M)\hyd t \Gamma $&$:=$&$ \lambda x . (M\hyd t \Gamma)$\\
$x\hyd t \Gamma$ &$:=$&
  $\begin{cases}x\sem t&\hbox{if $x :: A\simp \in \Gamma$;}\\
 x&\hbox{otherwise.} \end{cases}$ \\
\end{tabular}\]

\subsection{Lemmas}

\begin{lemma}
\label{hyd.erase.inv}
Rehydrating and erasure are inverses.
\end{lemma}

\begin{proof}

\cqed
\end{proof}

\begin{lemma}
\label{hyd.pres}
The rehydrating substitution is well-typed.
\[ \Gamma \prov t : H \qquad \Gamma\erase \prov A\simp : \rtype
\over
\Gamma \prov A\simp \hyd t \Gamma : \rtype\]
\end{lemma}

\begin{proof}

\cqed
\end{proof}

\begin{lemma}
Erasure is well-typed.
\label{erase.pres}
\begin{enumerate}
\item If $\prov \Gamma \rctx$, then $\prov \Gamma \erase \rctx$.
\item If $ \Gamma \prov A :\rtype$, then $ \Gamma\erase \prov A\erase :\rtype$.
\item If $ \Gamma \prov M :A$, then $ \Gamma\erase \prov M\erase : A\erase$.
\end{enumerate}
\end{lemma}

\begin{proof}

\cqed
\end{proof}

\begin{lemma}
\label{lock.pres}
Locking is well-typed. If $\prov \Gamma\simp \rctx$, then $\prov \Gamma\simp \locking \rctx$.
\end{lemma}

\begin{proof}

\cqed
\end{proof}

\subsection{Translation}
I want to define another map $\dash\thead$ that takes expressions to simple
expressions, but at the ``head of the arrow'' intsead of how
$\dash\erase$ is at the ``tail''. I'll need to define a substitution $\Gamma\tsub$ with
 $\Gamma\thead \prov \Gamma\tsub : \Gamma\erase$.
\[\begin{tabular}{rcl}
 $(\Gamma, x : A)\thead$&$:=$&$\Gamma\thead, x : A\thead $\\
 $(\Gamma, x :: A\simp)\thead$&$:=$&$\Gamma\thead, x : \Gamma\tsub A\simp $\\
 $H\thead$&$:=$&$0$\\
 $(A \to B)\thead$&$:=$&$(f\thead : A\thead \to B\thead) (f\erase : \Gamma\tsub A\erase \to \Gamma\tsub B\erase) \x  $\\
&& $\quad (x : A\thead) \to B\tsub(f\thead\ x) \equiv f\erase\ (A\tsub(x))$\\
\end{tabular}\]

\subsubsection{Substitution}
The general typing rule for substitutions is
\[
\begin{prooftree}
\Delta\simp \prov \theta\simp : \Gamma\simp \qquad \Delta\simp\prov M\simp : \theta\simp A\simp
\justifies
\Delta\simp \prov \theta\simp[M\simp /x] : (\Gamma\simp, x : A\simp)
\end{prooftree}
\]
We define here $\Gamma\thead \prov \Gamma\tsub : \Gamma\erase$.
\[\begin{tabular}{rcl}
 $(\Gamma, x : A)\tsub$&$:=$&$\Gamma\tsub[A\tsub(x)/x] $\\
 $(\Gamma, x :: A\simp)\tsub$&$:=$&$\Gamma\tsub[x/x]$\\
\end{tabular}\]

\subsection{Proofs about Translation}
These are mutually inductive.
\begin{lemma}
   If $\prov \Gamma \rctx$, then $\prov \Gamma\thead \rctx$
  \label{thead.ctx.pres}
\end{lemma}
\begin{proof}\ %
  \begin{itemize}
  \item [Case:]
\[
\begin{prooftree}
\prov \Gamma \rctx \qquad \Gamma \prov A : \rtype
\justifies
\prov (\Gamma, x : A)\rctx
\end{prooftree}
\]
By i.h., it remains to show  $\Gamma\thead \prov A\thead  : \rtype$.
We do this by applying Lemma~\ref{thead.type.pres}.

  \item [Case:]
\[
\begin{prooftree}
\prov \Gamma \rctx \qquad \Gamma\erase \prov A\simp : \rtype
\justifies
\prov (\Gamma, x :: A\simp)\rctx
\end{prooftree}
\]
By i.h., it remains to show  $\Gamma\thead \prov \Gamma\tsub A\simp : \rtype$.
We do this by applying Lemma~\ref{tsub.ctx.pres}.


  \end{itemize}
\cqed
\end{proof}
\begin{lemma}
   If $\prov \Gamma \rctx$, then $\Gamma\thead \prov \Gamma\tsub : \Gamma\erase$
  \label{tsub.ctx.pres}
\end{lemma}
\begin{proof}\ %
  \begin{itemize}
  \item [Case:]
\[
\begin{prooftree}
\prov \Gamma \rctx \qquad \Gamma \prov A : \rtype
\justifies
\prov (\Gamma, x : A)\rctx
\end{prooftree}
\]
Here we must show  $\Gamma\thead, x : A\thead \prov \Gamma\tsub[A\tsub(x) /x] : (\Gamma\erase, x : A\erase)$.
We do this by applying
\[
\begin{prooftree}
\[
  \hbox{i.h.}
  \justifies
  \Gamma\thead \prov \Gamma\tsub : \Gamma\erase
\]
\[
  \hbox{Lemma \ref{tsub.type.pres}}
  \justifies
  \Gamma\thead, x : A\thead\prov A\tsub(x) : \Gamma\tsub A\erase
\]
\justifies
\Gamma\thead, x : A\thead \prov \Gamma\tsub[A\tsub(x) /x] : (\Gamma\erase, x : A\erase)
\end{prooftree}
\]
  \item [Case:]
\[
\begin{prooftree}
\prov \Gamma \rctx \qquad \Gamma\erase \prov A\simp : \rtype
\justifies
\prov (\Gamma, x :: A\simp)\rctx
\end{prooftree}
\]
Here we must show  $\Gamma\thead, x : \Gamma\tsub A\simp \prov \Gamma\tsub[x/x] : (\Gamma\erase, x : A\simp)$.
We do this by applying
\[
\begin{prooftree}
\[
  \hbox{i.h.}
  \justifies
  \Gamma\thead \prov \Gamma\tsub : \Gamma\erase
\]
\[
  \justifies
  \Gamma\thead, x : \Gamma\tsub A\simp\prov x : \Gamma\tsub A\simp
\]
\justifies
\Gamma\thead, x : \Gamma\tsub A\simp \prov \Gamma\tsub[x /x] : (\Gamma\erase, x : A\simp)
\end{prooftree}
\]
  \end{itemize}
\cqed
\end{proof}
\begin{lemma}
   If $\Gamma \prov A : \rtype$, then $\Gamma\thead \prov A\thead : \rtype$
  \label{thead.type.pres}
\end{lemma}
\begin{proof}

\cqed
\end{proof}
\begin{lemma}
  \label{tsub.type.pres}
   If $\Gamma \prov A : \rtype$ then $\Gamma\thead, x : A\thead \prov A\tsub(x) : \Gamma\tsub A\erase$
\end{lemma}
\begin{proof}
Let's consider the function case. We have
$\Gamma \prov A \to B : \rtype$ and we need to show
\[\Gamma\thead, x : (A \to B)\thead \prov (A \to B)\tsub(x) : \Gamma\tsub (A \to B)\erase\]
which is
\[\Gamma\thead, f\thead : (A\thead \to B\thead), f\erase : (\Gamma\tsub A\erase \to \Gamma\tsub B\erase),\]
\[p : (x : A\thead) \to B\tsub(f\thead\ x) \equiv f\erase\ (A\tsub(x))\]
\[ \prov (A \to B)\tsub(f\thead, f\erase, p) : \Gamma\tsub A\erase \to \Gamma\tsub B\erase\]
So we simply set $(A \to B)\tsub(f\thead, f\erase, p) = f\erase$.
\cqed
\end{proof}
\begin{lemma}
  \label{thead.term.pres}
   If $\Gamma \prov M : A$, then $\Gamma\thead \prov M\thead : A\thead$
\end{lemma}
\begin{proof}\ %
\begin{itemize}
\item[Case:]
\[
\begin{prooftree}
\justifies
\Gamma, x : A, \Gamma' \prov x : A
\end{prooftree}
\]
After translating we get the obligation of showing
\[
\begin{prooftree}
\justifies
\Gamma\thead, x :  A\thead, \Gamma'\thead \prov x : A\thead
\end{prooftree}
\]
This is trivial.
\item[Case:]
\[
\begin{prooftree}
\Gamma \prov t : H\qquad x :: A\simp \in \Gamma
\justifies
\Gamma \prov x\sem t : A\simp\hyd t \Gamma
\end{prooftree}
\]
Here we get $\Gamma\thead \prov t\thead : 0$, so we can abort on it. The target
type is $(A\simp\hyd t \Gamma)\thead$. So we can set
\[ (x\sem t)\thead = \babort_{(A\simp\hyd t \Gamma)\thead} t\thead\]
\end{itemize}
\cqed
\end{proof}
\begin{lemma}
  \label{tsub.term.pres}
   If $\Gamma \prov M : A$, then $\Gamma\thead \prov \Gamma\tsub M\erase = A\tsub (M\thead) : \Gamma\tsub A\erase$
\end{lemma}

\begin{proof}

\cqed
\end{proof}

\section{An Intuition}

I think of the interval type $\I$ as being substructural, so it's not a $\rtype$ but rather a $W \to \rtype$
for some unknown type $W$. A `wide' type is indexed over both $w : W$ and $i : \I\ w$. The presheaf exponential
is realized as the definition of a logical connective taking two wide types and yielding a wide type.
Let $A, B : (w : W) (i : \I\ w) \to \rtype$ be given. We want to define
\[ A \to B : (w : W) (i : \I\ w) \to \rtype \]
somehow. We postulate
\[0, 1 :  \I\ \star\]
for some concrete empty world $\star$.
Let's write $\wat i$ for application to $\star$ and then $i$.
I want
\[(A \to B)\wat 0 \equiv (f_0 : A\wat 0 \to B\wat 0)
(f_1 : A\wat 1 \to B\wat 1) \x (\cdots \equiv \cdots)\]
\[(A \to B)\wat 1 \equiv A\wat 1 \to B\wat 1 \]
There's some way in which if I have $f : (w : W) (i : \I\ w) \to \rtype$ then I get
$\mu f : f\wat 0 \to f\wat 1$.

If I have $A : \rtype$ and $B : \rtype$ and $f : A \to B$, then there should exist
a wide type $G(A, B, f) : (w : W) (i : \I\ w) \to \rtype$ such that
$G(A, B, f)\wat 0 = A$ and $G(A, B, f)\wat 1 = B$ and $\mu(G(A, B, f)) = f$.

If I start with $q : (X : \rtype) \to X \to X$ and I'm in a context with $ (w : W) (i : \I\ w)$
and I investigate
\[  (w : W) (i : \I\ w) \prov q (G(A, B, f, w, i)) : G(A, B, f, w, i) \to G(A, B, f, w, i) \]
what do I get?

Let's back off and try to remember parametricity-in-parametricity for unary relations.
Given $p : A \to  B$ let's make
\begin{tabbing}
$\mathbf{data}\ \mathsf{Gel}\ (\I : \rtype) (e : \I) : \I \to \rtype\  \mathbf{where}$\\
\qquad $\mathsf{apt} : (a : A) (i : \I) \to \mathsf{Gel}\ i$\\
\qquad $\mathsf{bpt} : (b : B) \to \mathsf{Gel}\ e$\\
\qquad $\mathsf{path} : (a : A) \to \mathsf{apt}\ a\ e \equiv \mathsf{bpt}\ (p\ a)$
\end{tabbing}
If we consider $\mathsf{Gel}\ 2\ \binl\ \binr$ then we can only use $\mathsf{apt}\ a\ \binr$.
If we consider $\mathsf{Gel}\ 1\ \star\ \star$ then the only thing we can do up to equality
is $\mathsf{bpt}\ b$.

For $n$-ary:
Given $p : (s : S) \to A \to  (B\ s)$  let's make
\begin{tabbing}
$\mathbf{data}\ \mathsf{Gel}\ (\I : \rtype) (\eta : S \to  \I) : \I \to \rtype\  \mathbf{where}$\\
