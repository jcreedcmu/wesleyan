\subsection{Lemmas}

\begin{lemma}\ %
\begin{enumerate}
\item If $\prov \Gamma \rctx$, then $\prov \Gamma ^* \rctx$.
\item If $ \Gamma \prov A :\rtype$, then $ \Gamma^* \prov A^* :\rtype$.
\item If $ \Gamma \prov M :A$, then $ \Gamma^* \prov M^* : A^*$.
\end{enumerate}
\end{lemma}

\begin{proof}
Let's consider some interesting cases.
\begin{itemize}
\item [Case:]
\[
\begin{prooftree}
 x : A \in \Gamma
\justifies
\Gamma \prov x : A
\end{prooftree}
\]
We must show $\Gamma^* \prov x : A^*$ but this follows from the assumption.
\item [Case:]
\[
\begin{prooftree}
\Gamma \prov t : H\qquad x :: A^* \in \Gamma
\justifies
\Gamma \prov x[t] : A
\end{prooftree}
\]
We must show $\Gamma^* \prov x : A^*$. But $x : A^* \in \Gamma^*$ by assumption,
so we're done.
\end{itemize}
\cqed
\end{proof}

\begin{lemma}\ %
\begin{enumerate}
\item If $\prov \Gamma \rctx$, then $\prov \sem\Gamma  \rctx$.
\item If $ \Gamma \prov A :\rtype$, then $ \sem\Gamma, x : A^* \prov \sem A(x) :\rtype$.
\item If $ \Gamma \prov M :A$, then $ \sem\Gamma \prov \sem M : \sem A(M^*)$.
\end{enumerate}
\end{lemma}

\begin{proof}
Let's consider some interesting cases.
\begin{itemize}
\item [Case:]
\[
\begin{prooftree}
 x : A \in \Gamma
\justifies
\Gamma \prov x : A
\end{prooftree}
\]
We must show $\sem \Gamma \prov x' : \sem A (x)$. But $x : A \in \Gamma$
guarantees $x' : \sem A (x) \in \sem \Gamma$.
\item [Case:]
\[
\begin{prooftree}
\Gamma \prov t : H\qquad x :: A^* \in \Gamma
\justifies
\Gamma \prov x[t] : A
\end{prooftree}
\]
We must show $\sem \Gamma \prov \babort(\sem t) : \sem A(x)$.
But the induction hypothesis guarantees $\sem \Gamma \prov \sem t : 0$
so the abort succeeds.
\end{itemize}
\cqed
\end{proof}

\begin{lemma}
$(\Gamma_0)^{+*} = \Gamma_0$
\end{lemma}


\begin{lemma}
 If $\prov \Gamma_0 \rctx$, then $\prov \Gamma\simp^+  \rctx$.
\end{lemma}

\section{Extensions}
\subsection{The Amazing Right Adjoint}
\[\begin{tabular}{rccl}
  Types&$A$&$::=$&$\cdots \celse \surd A $\\
  Terms&$M$&$::=$&$\cdots \celse \surd M \celse \had \lambda . M $\\
\end{tabular}\]
\[
\begin{prooftree}
\Gamma^{*+} \prov A : \rtype
\justifies
\Gamma \prov \surd A : \rtype
\end{prooftree}
\qquad
\begin{prooftree}
\Gamma^{*+} \prov M : A
\justifies
\Gamma \prov \surd M : \surd A
\end{prooftree}
\qquad
\begin{prooftree}
\Gamma, h : H \prov M : \surd A
\justifies
\Gamma \prov \hat \lambda h . M : A[\Gamma, h : H][\star/h]
\end{prooftree}
\]

We need a new substitution principle:
\[\begin{tabular}{rcp{5cm}}
$(x[t]) [\Gamma]$ &$:=$&
  $\begin{cases}x[t]&\hbox{if $x :: A\simp \in \Gamma$;}\\
 x&\hbox{otherwise.} \end{cases}$ \\
\end{tabular}\]

\begin{lemma}\ %
  \begin{itemize}
  \item If $\prov \Gamma^{*+}, \Delta \rctx$ then $\prov \Gamma, \Delta[\Gamma] \rctx$.
  \item If $\Gamma^{*+}, \Delta \prov A : \rtype$ then $\Gamma, \Delta[\Gamma] \prov A[\Gamma] : \rtype$.
  \item If $\Gamma^{*+}, \Delta \prov M : A$ then $\Gamma, \Delta[\Gamma] \prov M[\Gamma] : A[\Gamma]$.
  \end{itemize}
\end{lemma}

\begin{proof}
Let's consider the variable cases.
\begin{itemize}
\item [Case:]
\[
\begin{prooftree}
\Gamma^{*+}, \Delta \prov t : H\qquad x :: A^* \in \Gamma^{*+}
\justifies
\Gamma^{*+}, \Delta \prov x[t] : A
\end{prooftree}
\]
We must show $\Gamma, \Delta[\Gamma] \prov x[t] : A[\Gamma]$.
\item [Case:]
\[
\begin{prooftree}
\Gamma^{*+}, \Delta \prov t : H\qquad x :: A^* \in \Delta
\justifies
\Gamma^{*+}, \Delta \prov x[t] : A
\end{prooftree}
\]
\end{itemize}
\cqed
\end{proof}


\section{Different Syntax}

What if I do this:
\subsection{Language}
We have basic syntax $\Gamma\simp, A\simp, M\simp$
with all the usual typing rules.

We introduce some `wide' syntax
\[\begin{tabular}{rccl}
  Wide Contexts&$ \Gamma$&$::=$&$\cdot \celse \Gamma, x : A $\\
  Wide Variables&$ x$&$::=$&$ (x^*,\sem x) $\\
  Wide Types&$ A$&$::=$&$ (A\simp, x^*.A'\simp) $\\
  Wide Terms&$ M$&$::=$&$ (M\simp, M'\simp)$\\
\end{tabular}\]
Every wide type is a pair of basic types, the second
with one extra bound variable, ranging over basic terms.

Every wide term is a pair of basic terms.

A `wide variable' is a pair of basic variables. We always
name the basic variables consistently in such a way that
they can be related to one another and to the wide
variable they came from.

The programme is that we will introduce new wide type and term
constructors as {\em admissible rules} derived from the more fundamental rules defined
below.

\subsection{Typing Rules}
\subsubsection{Context Formation}
\[
\begin{prooftree}
\prov \Gamma \rctx \qquad \Gamma \prov A : \rtype
\justifies
\prov (\Gamma, x : A)\rctx
\end{prooftree}
\]
\subsubsection{Type Formation}
\[
\begin{prooftree}
\Gamma^* \prov A^*: \rtype \qquad \sem \Gamma, x^* : A^* \prov \sem A(x^*) : \rtype
\justifies
\Gamma \prov A : \rtype
\end{prooftree}
\]
\subsubsection{Term Typing}
\[
\begin{prooftree}
\Gamma^* \prov M^*: A^* \qquad \sem \Gamma \prov \sem M : \sem A(M^*)
\justifies
\Gamma \prov M : A
\end{prooftree}
\]
\subsection{Operations}
\subsubsection{Erasure}
We define an operation $\dash^*$ that takes wide (contexts, types, terms) to simple (contexts, types, terms).
\[\begin{tabular}{rcl}
 $(\Gamma, x : A)^*$&$:=$&$(\Gamma^*, x^* : A^*) $\\
 $( A\simp, x^*.A'\simp)^*$&$:=$&$A\simp $\\
 $(M\simp, M'\simp)^*$&$:=$&$M\simp $\\
\end{tabular}\]

\subsubsection{Interpretation}
We define an operation $\sem \dash$ that takes wide (contexts, terms) to simple (contexts, terms).
We define an operation $\sem \dash(\dash)$ that takes a wide type and a simple term to a simple type.
\[\begin{tabular}{rcl}
 $\sem{\Gamma, x : A}$&$:=$&$(\sem \Gamma, x^* : A^*, \sem x : \sem A(x^*)) $\\
 $\sem {( A\simp, x^*.A'\simp)}(M\simp)$&$:=$&$[M\simp/x^*]A'\simp $\\
 $\sem {(M\simp, M'\simp)}$&$:=$&$M'\simp $\\
\end{tabular}\]


\subsection{Lemmas}
\begin{lemma}[Extensionality] For any $A$, $M$, we have
\[ A = (A^*, x^*. \sem A(x^*))\]
\[ M = (M^*, \sem M)\]
\end{lemma}

\begin{proof}
Any $A$ must be of the form $(A\simp, y^*.A'\simp)$, so by unfolding definitions, we need to check
\[ (A\simp, y^*.A'\simp) = (A\simp, x^*.  [x^*/y^*]A'\simp)\]
which is reflexivity up to $\alpha$-equivalence.

Any $M$ must be of the form $(M\simp, M'\simp)$, so by unfolding definitions, we need to check
\[(M\simp, M'\simp) = (M\simp, M'\simp)\]
which is reflexivity.
\cqed
\end{proof}

\begin{lemma} The rule
\[\begin{prooftree}x :A \in \Gamma \justifies \Gamma \prov x : A\end{prooftree}\]
is admissible.
\end{lemma}


\begin{proof}
By assumption, we know $x^* : A^* \in \Gamma^*$. Hence $\Gamma^* \prov x^* : A^*$.
By assumption, we know $x^* : A^*, \sem x : \sem A(x^*) \in \sem \Gamma$.
Hence $\sem \Gamma \prov \sem x : \sem A(x^*)$.
These two facts together mean
\[\Gamma \prov (x^*, \sem x) : (A^*, x^*.\sem A(x^*))\]
in other words, $\Gamma \prov x : A$.
\cqed
\end{proof}

\subsection{Pi}
We make the definitions
\[\begin{tabular}{rcl}
$ (x:A) \to B $&$:=$&$((x^*:A^*) \to B^*, f^*.(x^*:A^*) \to (\sem x : \sem A(x^*)) \to \sem B(f^*\ x^*)$\\
 $\lambda x . M $&$:=$&$(\lambda x^*.M^*, \lambda x^* .\lambda \sem x . \sem M)$\\
 $M\ N $&$:=$&$(M^*\ N^*, \sem M\ N^*\ \sem N)$\\
\end{tabular}\]


\begin{lemma} The rule
\[\begin{prooftree}\Gamma \prov A : \rtype \qquad \Gamma, x : A \prov B : \rtype
\justifies
\Gamma \prov (x : A) \to B : \rtype
\end{prooftree}
\]
is admissible.
\end{lemma}


\begin{proof}
The $\dash^*$ reasoning is easy. For $\sem \dash$, we know
\[\sem \Gamma, x^* : A^* \prov \sem A(x^*) : \rtype \]
\[ \sem \Gamma, x^* : A^*, \sem x : \sem A(x^*), y^* : B^*  \prov \sem B (y^*): \rtype\eqno(*)\]

We need
\[\sem \Gamma, f^* : (x^*:A^*) \to B^* \prov (x^*:A^*) \to (\sem x : \sem A(x^*)) \to \sem B(f^*\ x^*) : \rtype\]
and therefore we need
\[\sem \Gamma \prov A^* : \rtype\]
\[\sem \Gamma, x^*:A^* \prov \sem A(x^*)  : \rtype\]
\[\sem \Gamma, f^* : (x^*:A^*) \to B^*, x^*:A^*, \sem x : \sem A(x^*) \prov \sem B(f^*\ x^*) : \rtype\]
We have the first by assumption (on the $\dash^*$ part)
We have the second by assumption (on the $\sem\dash$ part)
And finally we have the third by substitution of $f^*\ x^*$ for $y^*$ in $(*)$.

\cqed
\end{proof}

