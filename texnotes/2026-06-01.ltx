\section{Language}
\[\begin{tabular}{rccl}
 Simple Contexts&$\Gamma\simp$&$::=$&$\cdot \celse \Gamma\simp, x : A\simp$\\
 Simple Types&$A\simp$&$::=$&$\cdots  $\\
 Simple Terms&$M\simp$&$::=$&$\cdots  $\\
\end{tabular}\]

\[\begin{tabular}{rccl}
  Contexts&$\Gamma$&$::=$&$\cdot \celse \Gamma, x : A \celse \Gamma, x :: A\simp$\\
  Types&$A$&$::=$&$\cdots \celse H $\\
  Terms&$M$&$::=$&$\cdots \celse x [ M] $\\
\end{tabular}\]

\subsection{Operations}
\[\begin{tabular}{l}
If $\Gamma$ is a context, then $\Gamma^*$ is a simple context.\\
If $A$ is a type, then $A^*$ is a simple type.\\
If $M$ is a term, then $M^*$ is a simple term.\\
If $\Gamma$ is a context, then $\sem \Gamma$ is a simple context.\\
If $A$ is a type, and $M\simp$ is a simple term, then $\sem A(M\simp)$ is a simple type.\\
If $M$ is a term, then $\sem M$ is a simple term.\\
If $\Gamma\simp$ is a context, then $\Gamma\simp^+$ is a context.\\
% If $\Gamma$ is a context, $t$ is a term, $A\simp$ is a simple type, then $A\simp \hyd t \Gamma$ is a type.\\
\end{tabular}\]


\subsection{Judgments}
\[\begin{tabular}{rl}
  Simple Context Formation&$\prov \Gamma\simp \rctx$\\
  Simple Type Formation&$\Gamma\simp \prov A\simp : \rtype$\\
  Simple Term Typing&$\Gamma\simp \prov M\simp : A\simp$\\
  Context Formation&$\prov \Gamma \rctx$\\
  Type Formation&$\Gamma \prov A : \rtype$\\
  Term Typing&$\Gamma \prov M : A$\\
\end{tabular}\]

\subsection{Rules}

\subsubsection{Context Formation}
\[
\begin{prooftree}
\prov \Gamma \rctx \qquad \Gamma \prov A : \rtype
\justifies
\prov (\Gamma, x : A)\rctx
\end{prooftree}
\]
\[
\begin{prooftree}
\prov \Gamma \rctx \qquad \Gamma^* \prov A\simp : \rtype
\justifies
\prov (\Gamma, x :: A\simp)\rctx
\end{prooftree}
\]
\subsubsection{Term Typing}
\[
\begin{prooftree}
\Gamma \prov t : H\qquad x :: A^* \in \Gamma
\justifies
\Gamma \prov x[t] : A
\end{prooftree}
\]
\subsection{Operations}

\subsubsection{Erasure}
\[\begin{tabular}{rcl}
 $(\Gamma, x : A)^*$&$:=$&$(\Gamma^*, x : A^*) $\\
 $(\Gamma, x :: A\simp)^*$&$:=$&$(\Gamma^*, x : A\simp) $\\
 $((a : A) \to B)^*$&$:=$&$(a : A^*) \to B^*$\\
 $(\lambda a . M)^*$&$:=$&$\lambda a  .  M^*$\\
 $(M\ N)^*$&$:=$&$M^*\ N^*$\\
 $H^*$&$:=$&$1 $\\
 $(x[t])^*$&$:=$&$x $\\
 $x^*$&$:=$&$x $\\
\end{tabular}\]

\subsubsection{Relational Semantics}
\[\begin{tabular}{rcl}
 $\sem{\Gamma, x : A}$&$:=$&$(\sem \Gamma, x : A^*, x' : \sem A(x)) $\\
 $\sem{\Gamma, x :: A\simp}$&$:=$&$(\sem \Gamma, x : A\simp )$\\
 $\sem{(a : A) \to B}(f)$&$:=$&$(a : A^*)(a' : \sem A (a)) \to \sem B (f\ a) $\\
 $\sem{\lambda a . M}$&$:=$&$\lambda a.\lambda a' . \sem M$\\
 $\sem{M\ N}$&$:=$&$\sem M\ N^*\ \sem N$\\
 $\sem{H}(\star)$&$:=$&$0 $\\
 $\sem{x[t]}$&$:=$&$\babort(\sem t) $\\
 $\sem{x}$&$:=$&$x' $\\
\end{tabular}\]

\subsubsection{Promotion}
\[\begin{tabular}{rcl}
 $(\Gamma\simp, x : A\simp)^+$&$:=$&$(\Gamma\simp^+, x :: A\simp) $\\
\end{tabular}\]

