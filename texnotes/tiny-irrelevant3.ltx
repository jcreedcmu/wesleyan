\section{Introduction}
The purpose of this note is to describe a small modal type theory in which we can do a little bit of internalized
parametricity. It is not a goal to do iterated internalized parametricity. It {\em is} a goal to have the type system
in some sense ``tell us itself'' what parametricity means for each type in it. That is, we aim to set up judgments
and types and intro and elim rules in such a way that various type isomorphisms arise as emergent facts.
So instead of {\em defining} that a value $f : A \to B$ ``belongs to the logical relation'' at type $A \to B$ if and
only if for every $a : A$ which belongs to the relation at type $A$ we have that $f\ a$ belongs to the relation
at type $B$, we are able to construct this as a term internally in the system.

We avoid introducing an explicit interval object. We avoid introducing any computational principles
that are divorced from any particular logical-connective/type-former.

One pervasive intuition that is helpful to lean on is that we are, in this theory,
``programming in the presheaf category $\rtype^{\bf 2}$'', where $\bf 2$ is the category
with two objects and one trivial morphism.

\section{Language}


The type theory is modal and has two levels. There is the $\wid{\hbox{wide}}$ level and the $\nar{\hbox{narrow}}$ level.
In both levels, we have several sorts of variables in the context.
Variables may be ordinary $x : \wid A$, strong $x :: \wid A$, or weak $x \div \nar A$.



\[\begin{tabular}{rccl}
 Wide Contexts&$\wid \Gamma$&$::=$&$\cdot  \celse \wid\Gamma, x :: \wid A \celse \wid\Gamma, x \div \nar A  \celse \wid \Gamma, x : \wid A$\\
  Narrow Contexts&$\nar\Gamma$&$::=$&$\cdot \celse \nar \Gamma, x :: \wid A\celse \nar \Gamma, x \div \nar A  $\\
  Wide Types&$\wid A$&$::=$&$\cdots
% \celse \wid \gg (x : \nar A) . \nar B
  \celse \dia {\nar A}
$\\
  Narrow Types&$\nar A$&$::=$&$\cdots
  \celse \pp {\nar M} {\wid A}
  \celse \surd \wid A
$\\
Wide  Terms&$\wid M$&$::=$&$\cdots
\celse \esurd \nar M
$\\
Narrow  Terms&$\nar M$&$::=$&$\cdots
\celse \isurd \wid M
$\\
\end{tabular}\]

\subsection{Semantics}
We imagine the target language of our `semantics' to be ordinary dependent type theory
with no exotic contexts or types or terms.
We define operations $\dash^*$ and $\sem\dash$ and $\tsem\dash\dash$ so that syntactically:

\begin{tabular}{l}
If $\wid \Gamma$ is a wide context, then ${\wid \Gamma}^*$ is a context.\\
If $\wid A$ is a wide type, then ${\wid A}^*$ is a type.\\
If $\wid M$ is a wide term, then ${\wid M}^*$ is a term.
If $\wid \Gamma$ is a wide context, then $\sem{\wid \Gamma}$ is a context.\\
If $\wid A$ is a wide type and $M$ is a term, then $\tsem {\wid A} {M}$ is a type.\\
If $\wid M$ is a wide term, then $\sem{\wid M}$ is a term.\\
If $\nar \Gamma$ is a narrow context, then ${\nar \Gamma}^*$ is a context.\\
If $\nar A$ is a narrow type, then ${\nar A}^*$ is a type.\\
If $\nar M$ is a narrow term, then ${\nar M}^*$ is a term.
\end{tabular}

\noindent Furthermore we wish to prove that these operations preserve typing:

\begin{lemma}[Type Semantic Soundness]\ %
\label{semantic.soundness.type}
  \begin{enumerate}[noitemsep]
\item If ${\wid\Gamma} \wprov {\wid A} : \rtype$, then ${\wid\Gamma}^* \prov {\wid A}^* : \rtype$.
\item If ${\wid\Gamma} \wprov {\wid A} : \rtype$, then $\sem {\wid\Gamma}, x : \wid {\wid A}^* \prov \tsem {\wid A} x : \rtype$.
\item If ${\nar\Gamma} \nprov {\nar A} : \rtype$, then ${\nar\Gamma}^* \prov {\nar A}^* : \rtype$.
  \end{enumerate}
\end{lemma}

\begin{lemma}[Term Semantic Soundness]\ %
\label{semantic.soundness.term}
  \begin{enumerate}[noitemsep]
\item If ${\wid\Gamma} \wprov {\wid M} : {\wid A}$, then ${\wid\Gamma}^* \prov {\wid M}^* : {{\wid A}}^*$.
\label{semantic.soundness.wide.term.star}
\item If ${\wid\Gamma} \wprov {\wid M} : {\wid A}$, then $\sem{\wid\Gamma} \prov \sem {\wid M} : \tsem {\wid A} {\wid M^*}$.
\label{semantic.soundness.wide.term.brackets}
\item If ${\nar\Gamma} \nprov {\nar M} : {\nar A}$, then ${\nar\Gamma}^* \prov {\nar M}^* : {{\nar A}}^*$.
\label{semantic.soundness.narrow.term.star}
  \end{enumerate}
\end{lemma}

\begin{proof}
Distributed throughout various sections.
\cqed
\end{proof}

\subsection{Erasure}
Erasure $|\dash|$ takes a wide type or term and turns it into a narrow type or term.

\[
\begin{tabular}{rcl}
 $ \erase{\dia \nar A}$&$:=$&$\nar A$\\
 $ \erase{\idia \nar M}$&$:=$&$\nar M$\\
 $ \erase{\esurd \nar M}$&$:=$&$\textcolor{red}{???}$\\
\end{tabular}
\]

\begin{lemma}
\label{erase.type}
If $\wid \Gamma \wprov \wid A : \rtype$, then
 $\demote{\wid \Gamma} \nprov \erase{\wid A} : \rtype$.
\end{lemma}

\begin{lemma}
\label{erase.term}
If $\wid \Gamma \wprov \wid M : \wid A$, then
 $\demote{\wid \Gamma} \nprov \erase{\wid M} : \erase{\wid A} $.
\end{lemma}

\begin{lemma}
\label{erase.star.eq.star}
$\erase{\wid A}^* = \wid A^*$
\end{lemma}




\subsection{Inclusion}
Narrow contexts are a subset of wide contexts. We write $\ups$ for the explicit inclusion of narrow contexts into wide contexts.
\[
\begin{tabular}{rcl}
 $ \ups(\nar\Gamma, x :: \wid A)$&$:=$&$(\ups\nar\Gamma, x :: \wid A)$\\
 $ \ups(\nar\Gamma, x \div \nar A)$&$:=$&$(\ups\nar\Gamma, x \div \nar A)$\\
 $ \ups(\cdot)$&$:=$&$\cdot$\\
\end{tabular}\]

\begin{lemma}
\label{include.pres}
If $\nprov \nar \Gamma \rctx$, then
$\wprov \ups{\nar \Gamma} \rctx$.
\end{lemma}

\begin{proof}\ %
  \begin{itemize}
  \item
If we have
\[
\begin{prooftree}
\nprov {\nar\Gamma} \rctx \qquad {\nar\Gamma} \nprov \nar A : \rtype
\justifies
\nprov ({\nar\Gamma}, x \div \nar A)\rctx
\end{prooftree}
\]
then we construct (using Lemma~\ref{include.demote.eq.orig})
\[
\begin{prooftree}
\wprov {\ups\nar\Gamma} \rctx \qquad \demote {(\ups\nar\Gamma)} \nprov \nar A : \rtype
\justifies
\wprov ({\ups\nar\Gamma}, x \div \nar A)\rctx
\end{prooftree}
\]
  \item
If we have
\[
\begin{prooftree}
\nprov {\nar\Gamma} \rctx \qquad \ups {\nar\Gamma} \wprov \wid A : \rtype
\justifies
\nprov ({\nar\Gamma}, x :: \wid A)\rctx
\end{prooftree}
\]
then we construct (using Lemma~\ref{include.demote.eq.orig})
\[
\begin{prooftree}
\wprov {\ups\nar\Gamma} \rctx \qquad \ups(\demote{(\ups\nar\Gamma)}) \wprov \wid A : \rtype
\justifies
\wprov ({\ups\nar\Gamma}, x :: \wid A)\rctx
\end{prooftree}
\]
  \end{itemize}
\cqed
\end{proof}

\subsection{Demotion}
We define an operation $\dash^\ominus$ which takes a wide context to a narrow context.
Demotion turns normal variables into weak variables and leaves other variables alone.
%% Promotion
%% \[\begin{tabular}{rcl}
%%  $ (\Gamma, x : \wid A)^\oplus$&$:=$&$(\Gamma^\oplus, x :: \wid A)$\\
%%  $ (\Gamma, x :: \wid A)^\oplus$&$:=$&$(\Gamma^\oplus, x :: \wid A)$\\
%%  $ (\Gamma, x \div \nar A)^\oplus$&$:=$&$(\Gamma^\oplus, x \div \nar A)$\\
%%  $ (\Gamma, \star)^\oplus$&$:=$&$\emptyset$\\
%%  $ (\emptyset)^\oplus$&$:=$&$\emptyset$\\
%%  $ (\cdot)^\oplus$&$:=$&$\cdot$\\
%% \end{tabular}
%% \]


\[
\begin{tabular}{rcl}
 $ (\wid\Gamma, x : \wid A)^\ominus$&$:=$&$(\wid\Gamma^\ominus, x \div \erase{\wid A})$\\
 $ (\wid\Gamma, x :: \wid A)^\ominus$&$:=$&$(\wid\Gamma^\ominus, x :: \wid A)$\\
 $ (\wid\Gamma, x \div \nar A)^\ominus$&$:=$&$(\wid\Gamma^\ominus, x \div \nar A)$\\
 $ (\cdot)^\ominus$&$:=$&$\cdot$\\
\end{tabular}\]

\begin{lemma}
\label{include.demote.eq.orig}
$\demote{(\ups\nar\Gamma)} = \nar\Gamma$
\end{lemma}


\begin{lemma}
\label{demote.pres}
If $\wprov \wid \Gamma \rctx$, then
$\nprov \demote{\wid \Gamma} \rctx$.
\end{lemma}
\begin{proof}\ %
  \begin{itemize}
  \item If we have
\[
\begin{prooftree}
\wprov {\wid\Gamma} \rctx \qquad {\wid\Gamma} \wprov \wid A : \rtype
\justifies
\wprov ({\wid\Gamma}, x : \wid A)\rctx
\end{prooftree}
\]
then we construct (using Lemma~\ref{erase.type})
\[
\begin{prooftree}
\nprov {\demote{\wid\Gamma}} \rctx \qquad {\demote{\wid\Gamma}} \nprov \erase{\wid A} : \rtype
\justifies
\nprov ({\demote{\wid\Gamma}}, x \div \erase{\wid A})\rctx
\end{prooftree}
\]
  \item If we have
\[
\begin{prooftree}
\wprov {\wid\Gamma} \rctx \qquad \demote {\wid \Gamma} \nprov \nar A : \rtype
\justifies
\wprov ({\wid\Gamma}, x \div \nar A)\rctx
\end{prooftree}
\]
then we construct
\[
\begin{prooftree}
\nprov {\demote{\wid\Gamma}} \rctx \qquad {\demote{\wid\Gamma}} \nprov \nar A : \rtype
\justifies
\nprov ({\demote{\wid\Gamma}}, x \div \nar A)\rctx
\end{prooftree}
\]
  \item If we have
\[
\begin{prooftree}
\wprov {\wid\Gamma} \rctx \qquad \ups(\demote{\wid\Gamma}) \wprov \wid A : \rtype
\justifies
\wprov ({\wid\Gamma}, x :: \wid A)\rctx
\end{prooftree}
\]
then we construct
\[
\begin{prooftree}
\nprov {\demote{\wid\Gamma}} \rctx \qquad \ups (\demote{\wid\Gamma}) \wprov \wid A : \rtype
\justifies
\nprov ({\demote{\wid\Gamma}}, x :: \wid A)\rctx
\end{prooftree}
\]
  \end{itemize}
  \cqed
\end{proof}



\subsection{Rules}

\subsubsection{Context Formation}

\[
\begin{prooftree}
\justifies
\wprov \cdot \rctx
\end{prooftree}
\qquad
\begin{prooftree}
\justifies
\nprov \cdot \rctx
\end{prooftree}
\qquad
\begin{prooftree}
\wprov {\wid\Gamma} \rctx \qquad {\wid\Gamma} \wprov \wid A : \rtype
\justifies
\wprov ({\wid\Gamma}, x : \wid A)\rctx
\end{prooftree}
\]
\[
\begin{prooftree}
\wprov {\wid\Gamma} \rctx \qquad \demote {\wid \Gamma} \nprov \nar A : \rtype
\justifies
\wprov ({\wid\Gamma}, x \div \nar A)\rctx
\end{prooftree}
\qquad
\begin{prooftree}
\wprov {\wid\Gamma} \rctx \qquad \ups(\demote{\wid\Gamma}) \wprov \wid A : \rtype
\justifies
\wprov ({\wid\Gamma}, x :: \wid A)\rctx
\end{prooftree}
\]


\[
\begin{prooftree}
\nprov {\nar\Gamma} \rctx \qquad {\nar\Gamma} \nprov \nar A : \rtype
\justifies
\nprov ({\nar\Gamma}, x \div \nar A)\rctx
\end{prooftree}
\qquad
\begin{prooftree}
\nprov {\nar\Gamma} \rctx \qquad \ups {\nar\Gamma} \wprov \wid A : \rtype
\justifies
\nprov ({\nar\Gamma}, x :: \wid A)\rctx
\end{prooftree}
\]
Semantics:
\[
\begin{array}{rcl}
({\wid\Gamma}, x : \wid A)^* &=& ({\wid\Gamma}^*, x^* : {\wid A}^*)\\
({\wid\Gamma}, x :: \wid A)^* &=& ({\wid\Gamma}^*, x^* : {\wid A}^*, \sem x : \tsem {\wid A} {x^*})\\
({\wid\Gamma}, x \div \nar A)^* &=& ({\wid\Gamma}^*, x^* : {\nar A}^*)\\
\end{array}
\qquad
\begin{array}{rcl}
\sem{{\wid\Gamma}, x : \wid A} &=& (\sem{\wid\Gamma}, x^* : {\wid A}^*, \sem x : \tsem {\wid A} {x^*})\\
\sem{{\wid\Gamma}, x :: \wid A} &=& (\sem{\wid\Gamma}, x^* : {\wid A}^*, \sem x : \tsem {\wid A} {x^*})\\
\sem{{\wid\Gamma}, x \div \nar A} &=& (\sem{\wid\Gamma}, x^* : {\nar A}^*)\\
\end{array}
\]
\[
\begin{array}{rcl}
({\nar\Gamma}, x :: \wid A)^* &=& ({\nar\Gamma}^*, x^* : {\wid A}^*, \sem x : \tsem {\wid A} {x^*})\\
({\nar\Gamma}, x \div \nar A)^* &=& ({\nar\Gamma}^*, x^* : {\nar A}^*)\\
\end{array}
\]


\begin{lemma}
\label{semantic.weakening}
For any $\wid \Gamma$, the context ${\wid \Gamma}^*$ is a subset of $\sem{\wid \Gamma}$.
Therefore any judgment that holds in context in ${\wid \Gamma}^*$ also holds in
$\sem{\wid \Gamma}$.
\end{lemma}

\begin{lemma}
\label{include.brackets.eq.star}
$\sem{\ups \nar \Gamma} = \nar \Gamma^*$
\end{lemma}

\begin{lemma}
\label{include.star.eq.star}
$(\ups \nar \Gamma)^* = \nar \Gamma^*$
\end{lemma}


\begin{lemma}
\label{demote.star.eq.star}
$(\demote{\wid \Gamma})^* = \wid \Gamma^*$
\end{lemma}

\begin{proof}
By induction on $\wid \Gamma$, using Lemma~\ref{erase.star.eq.star}.
\cqed
\end{proof}


\begin{lemma}[Context Semantic Soundness]\ %
\label{semantic.soundness.context}
  \begin{enumerate}[noitemsep]
\item If $\wprov {\wid\Gamma}\rctx$, then $\prov {{\wid\Gamma}}^*\rctx$.
\item If $\wprov {\wid\Gamma}\rctx$, then $\prov \sem{{\wid\Gamma}}\rctx$.
\item If $\nprov {\nar\Gamma}\rctx$, then $\prov {{\nar\Gamma}}^*\rctx$.
  \end{enumerate}
\end{lemma}


\begin{proof}\ %
\begin{itemize}
\item
We know
\[
\begin{prooftree}
\wprov {\wid\Gamma} \rctx \qquad {\wid\Gamma} \wprov \wid A : \rtype
\justifies
\wprov ({\wid\Gamma}, x : \wid A)\rctx
\end{prooftree}
\]
and therefore
\[\prov \wid\Gamma^* \rctx \qquad \prov \sem{\wid\Gamma} \rctx\]
\[\wid\Gamma^* \prov \wid A^*:\rtype \qquad \sem{\wid\Gamma}, x^* : \wid A^* \prov \tsem{\wid A}{x^*} \]
which is enough to show
\[\prov ({\wid\Gamma}^*, x^* : {\wid A}^*) \rctx\qquad
\prov(\sem{\wid\Gamma}, x^* : {\wid A}^*, \sem x : \tsem {\wid A} {x^*}) \rctx\]
\item
We know
\[
\begin{prooftree}
\wprov {\wid\Gamma} \rctx \qquad \demote {\wid \Gamma} \nprov \nar A : \rtype
\justifies
\wprov ({\wid\Gamma}, x \div \nar A)\rctx
\end{prooftree}
\]
and therefore
\[\prov \wid\Gamma^* \rctx \qquad \prov \sem{\wid\Gamma} \rctx\]
\[(\demote{\wid\Gamma})^* \prov \nar A^*:\rtype \]
which is enough to show (using Lemma~\ref{semantic.weakening} and Lemma~\ref{demote.star.eq.star})
\[\prov ({\wid\Gamma}^*, x^* : {\nar A}^*) \rctx\qquad
\prov(\sem{\wid\Gamma}, x^* : {\nar A}^*) \rctx\]
\item
We know
\[
\begin{prooftree}
\wprov {\wid\Gamma} \rctx \qquad \ups(\demote{\wid\Gamma}) \wprov \wid A : \rtype
\justifies
\wprov ({\wid\Gamma}, x :: \wid A)\rctx
\end{prooftree}
\]
and therefore
\[\prov \wid\Gamma^* \rctx \qquad \prov \sem{\wid\Gamma} \rctx\]
\[(\ups(\demote{\wid\Gamma}))^* \prov \wid A^*:\rtype \qquad \sem{\ups(\demote{\wid\Gamma})}, x^* : \wid A^* \prov \tsem{\wid A}{x^*} \]
using Lemmas \ref{include.brackets.eq.star}, \ref{include.star.eq.star}, and~\ref{demote.star.eq.star} this is the same as
\[\wid\Gamma^* \prov \wid A^*:\rtype \qquad \wid\Gamma^*, x^* : \wid A^* \prov \tsem{\wid A}{x^*} \]
which is enough to show (also using Lemma~\ref{semantic.weakening})
\[\prov ({\wid\Gamma}^*, x^* : {\wid A}^*, \sem x : \tsem {\wid A} {x^*}) \rctx\qquad
\prov(\sem{\wid\Gamma}, x^* : {\wid A}^*, \sem x : \tsem {\wid A} {x^*}) \rctx\]
\item
We know
\[
\begin{prooftree}
\nprov {\nar\Gamma} \rctx \qquad {\nar\Gamma} \nprov \nar A : \rtype
\justifies
\nprov ({\nar\Gamma}, x \div \nar A)\rctx
\end{prooftree}
\]
and therefore
\[\prov \nar\Gamma^* \rctx \qquad \nar\Gamma^* \prov \nar A^*:\rtype \]
which is enough to show
\[\prov ({\nar\Gamma}^*, x^* : {\nar A}^*) \rctx\]
\item
We know
\[
\begin{prooftree}
\nprov {\nar\Gamma} \rctx \qquad \ups {\nar\Gamma} \wprov \wid A : \rtype
\justifies
\nprov ({\nar\Gamma}, x :: \wid A)\rctx
\end{prooftree}
\]
and therefore
\[\prov \nar\Gamma^* \rctx \]
\[ (\ups\nar\Gamma)^* \prov \wid A^*:\rtype \qquad \sem{\ups\nar\Gamma}, x^* : \wid A^* \prov \tsem{\wid A}{x^*} \]
Using Lemmas~\ref{include.brackets.eq.star} and~\ref{include.star.eq.star} we get
\[ \nar\Gamma^* \prov \wid A^*:\rtype \qquad \nar\Gamma^*, x^* : \wid A^* \prov \tsem{\wid A}{x^*} \]
which is enough to show
\[\prov ({\nar\Gamma}^*, x^* : {\wid A}^*, \sem x : \tsem {\wid A} {x^*}) \rctx\]
\end{itemize}
\cqed
\end{proof}

\subsubsection{Variable Rules}

\[
\begin{prooftree}
x : \wid A \in  \wid\Gamma
\justifies
\wid\Gamma \wprov x : \wid A
\end{prooftree}
\qquad
\begin{prooftree}
x :: \wid A \in  \wid\Gamma
\justifies
\wid\Gamma \wprov x : \wid A
\end{prooftree}
\]
\[
\begin{prooftree}
x \div \nar A \in  \nar\Gamma
\justifies
\nar\Gamma \nprov x : \nar A
\end{prooftree}
\qquad
\begin{prooftree}
x :: \wid A \in  \nar\Gamma
\justifies
\nar\Gamma \nprov x :  \erase {\wid A}
\end{prooftree}
\]

For the semantics we must check cases of \ref{semantic.soundness.term}. This is mostly straightforward, though
we need to invoke Lemma~\ref{erase.star.eq.star}.


\subsection{Type Formers}


\subsubsection{The Fiber Type}
\[
\begin{prooftree}
\ups\nar \Gamma \wprov \wid A : \rtype \quad \nar \Gamma \nprov \nar M : \erase {\wid A}
\justifies
\nar \Gamma \nprov \pp {\nar M} {\wid A} : \rtype
\end{prooftree}
\quad
\begin{prooftree}
\ups {\nar \Gamma} \wprov \wid M : \wid A
\justifies
\nar \Gamma \nprov \{\wid M\} : \pp  {\erase{\wid M}} {\wid A}
\end{prooftree}
\quad
\hbox{\textcolor{red} {FIXME}} \quad
\begin{prooftree}
\Gamma^Z \nprov \nar M : A^Z \quad \Gamma^\oplus \nprov \nar N : \pp {\nar M} A
\justifies
\Gamma \prov \epair {\nar M} {\nar N} : A
\end{prooftree}
\]

Semantics:
\[\begin{array}{rcl}
{\pp {\nar M} {\wid A}}^* &=& \tsem {\wid A} {\nar M^*}\\
\{\wid M\}^* &=& \sem {\wid M}\\
(\epair {\nar M} {\nar N})^* &=& {\nar M}^*\\
\end{array}
\qquad
\begin{array}{rcl}
\\
\\
\sem{\epair {\nar M}{\nar N}} &=& {\nar N}^*\\
\end{array}\]
\subsubsection{The Diagonal Modality}
\[
\begin{prooftree}
\demote{\wid \Gamma} \nprov  \nar A : \rtype
\justifies
\wid\Gamma \wprov  \dia \nar A : \rtype
\end{prooftree}
\qquad
\begin{prooftree}
 \demote{\wid\Gamma}\nprov \nar M : \nar A
\justifies
\wid \Gamma \wprov \idia \nar M  : \dia \nar A
\end{prooftree}
\]
Semantics:
\[\begin{array}{rcl}
{(\dia \nar A)}^* &=&  \nar A^*\\
(\idia \nar M)^* &=& \nar M^*\\
\end{array}
\qquad
\begin{array}{rcl}
\tsem{\dia \nar A}\_ &=& 1\\
\sem{\idia \nar M} &=& \langle\rangle\\
\end{array}\]

\subsubsection{The Open Modality}
\[
\begin{prooftree}
\demote{\wid \Gamma} \nprov  \nar A : \rtype
\justifies
\wid\Gamma \wprov  \lax \nar A : \rtype
\end{prooftree}
\qquad
\begin{prooftree}
 \Gamma, \star \prov M : A
\justifies
\Gamma \prov \ilax M  : \lax A
\end{prooftree}
\qquad
\begin{prooftree}
 \Gamma \prov M : \lax A\qquad \star \in \Gamma
\justifies
\Gamma \prov \elax M  : A
\end{prooftree}
\]
Semantics:
\[\begin{array}{rcl}
{(\lax \nar A)}^* &=&  \nar A^*\\
(\ilax M)^* &=& M^*\\
(\elax M)^* &=& M^*\\
\end{array}
\qquad
\begin{array}{rcl}
\tsem{\lax \nar A}\_ &=& 1\\
\sem{\ilax M} &=& \langle\rangle\\
\sem{\elax M} &=& \babort(\alpha)\\
\end{array}\]

\subsubsection{The Square Root Modality}
The modality $\surd$ can be thought of as the functor from $\rtype^{\bf 2}$ to itself that takes
any function $f : A \to B$ and returns the identity $A \to A$. To apply $\surd$ is to `retreat to the past world'
or `go upstairs', i.e. replace the data `downstairs' with the points that were formerly available upstairs.
\[
\begin{prooftree}
\ups \nar \Gamma \wprov \wid A : \rtype
\justifies
\nar \Gamma \nprov \surd \wid A : \rtype
\end{prooftree}
\qquad
\begin{prooftree}
 \ups\nar \Gamma \wprov \wid M : \wid A
\justifies
\nar \Gamma \nprov \isurd \wid M  : \surd \wid A
\end{prooftree}
\qquad
\begin{prooftree}
\demote{\wid \Gamma} \nprov \nar M : \surd \wid A
\justifies
\wid\Gamma \wprov \esurd \nar M  : \wid A
\end{prooftree}
\]
Semantics:
\[\begin{array}{rcl@{\qquad}rcl}
{(\surd \wid A)}^* &=&  (x : \wid A^*) \x \tsem {\wid A} x\\
(\isurd \wid M)^* &=& \pair {\wid M^*} {\sem {\wid M}}\\
(\esurd \nar M)^* &=& (\nar M^*).1 & \sem{\esurd \nar M} &=& (\nar M^*).2\\\\
\end{array}
\]
Let's check Lemmas~\ref{semantic.soundness.type}
and~\ref{semantic.soundness.term}.
If we've derived $\nar \Gamma \nprov \surd \wid A : \rtype$ then we're supposed to show
\[\nar \Gamma^* \prov (\surd \wid A)^* : \rtype\]
which is
\[\nar \Gamma^* \prov (x : \wid A^*) \x \tsem {\wid A} x : \rtype\]
so we need
\[\nar \Gamma^* \prov (x : \wid A^*) : \rtype\]
\[\nar \Gamma^*, x : \wid A^* \prov \tsem {\wid A} x : \rtype\]
and we get these from the premise, using Lemmas~\ref{include.brackets.eq.star} and~\ref{include.star.eq.star}.

Likewise if we've derived $\nar \Gamma \nprov \isurd \wid M  : \surd \wid A$, then we're supposed to show
\[\nar \Gamma^* \prov (\isurd \wid M)^*  : (\surd \wid A)^*\]
which is
\[\nar \Gamma^* \prov \pair {\wid M^*} {\sem {\wid M}}  : (x : \wid A^*) \x \tsem {\wid A} x\]
which requires
\[\nar \Gamma^* \prov  {\wid M^*}   : \wid A^*\]
\[\nar \Gamma^* \prov  {\sem {\wid M}}  :  \tsem {\wid A} {\wid M^*}\]
which again is just what the premise delivers, via Lemmas~\ref{include.brackets.eq.star} and~\ref{include.star.eq.star}.

Finally, if we've derived $\wid\Gamma \wprov \esurd \nar M  : \wid A$ then we need to show
\[\wid\Gamma^* \prov (\esurd \nar M)^*  : \wid A^*\]
\[\sem{\wid\Gamma} \prov \sem{\esurd \nar M}  : \tsem{\wid A}{ (\esurd \nar M)^*}\]
in other words
\[\wid\Gamma^* \prov ( \nar M^*).1  : \wid A^*\]
\[\sem{\wid\Gamma} \prov (\nar M^*).2  : \tsem{\wid A}{ ( \nar M^*).1}\]
The premise gives us
\[(\demote{\wid \Gamma})^* \prov \nar M^* :  (x : \wid A^*) \x \tsem {\wid A} x\]
which is just what we need (using Lemma~\ref{semantic.weakening}, Lemma~\ref{demote.star.eq.star})
\subsubsection{The Closed Modality}
The modality $\blat$ can be thought of as the functor from $\rtype^{\bf 2}$ to itself that takes
any function $f : A \to B$ and returns the unique map $A \to 1$. To apply $\blat$ is to destroy all distinctions
we formerly made `downstairs', while retaining all `upstairs' data.
\[
\begin{prooftree}
 \Gamma^\oplus \prov  A : \rtype
\justifies
\Gamma \prov  \blat A : \rtype
\end{prooftree}
\qquad
\begin{prooftree}
 \Gamma^\oplus \prov M : A
\justifies
\Gamma \prov \iblat M  : \blat A
\end{prooftree}
\qquad
\begin{prooftree}
 \Gamma^\ominus \prov M : \blat A
\justifies
\Gamma \prov \eblat M  : A
\end{prooftree}
\]
Semantics:
\[\begin{array}{rcl}
{(\blat A)}^* &=& 1\\
(\iblat M)^* &=& \langle\rangle\\
(\eblat M)^* &=& \sem M.1\\
\end{array}
\qquad
\begin{array}{rcl}
\tsem{\blat A}\_ &=&  (x : \wid A^*) \x \tsem A x\\
\sem{\iblat M} &=& \pair {M^*} {\sem M}\\
\sem{\eblat M} &=& \sem M.2\\
\end{array}\]

\subsubsection{The Glue Type}
The glue type takes specifications of a `downstairs' and `upstairs' type and glues them together.
\[
\begin{prooftree}
\Gamma, \star \prov A : \rtype \qquad \Gamma^\oplus, \star, x : \wid A\prov B : \rtype
\justifies
\Gamma \prov  \gg(x : \wid A) . B : \rtype
\end{prooftree}
\]
\[
\begin{prooftree}
\Gamma, \star \prov M : A  \qquad \Gamma^\oplus, \star \prov N : [M/x]B
\justifies
\Gamma \prov  \mpair M N : \gg(x : \wid A) . B : \rtype
\end{prooftree}
\]
\[
\begin{prooftree}
\Gamma \prov  M : \gg(x : \wid A) . B
\justifies
\Gamma, \star \prov M.1 : A
\end{prooftree}
\qquad
\begin{prooftree}
\Gamma \prov  M : \gg(x : \wid A) . B
\justifies
  \Gamma^\oplus, \star\prov M.2 : [M.1/x]B
\end{prooftree}
\]

Semantics:
\[\begin{array}{rcl}
{( \gg(x : \wid A) . B)}^* &=& A^*\\
\mpair M N ^* &=& M^*\\
(M.1)^* &=&  M^*\\
(M.2)^* &=& \sem M\\
\end{array}
\qquad
\begin{array}{rcl}
\tsem{ \gg(x : \wid A) . B} {M^*} &=&  [M^*/x^*]B^*\\
\sem{ \mpair M N } &=& N^*\\
\sem{M.1} &=& \babort(\alpha)\\
\sem{M.2} &=& \babort(\alpha)\\
\end{array}\]

\section{Interesting Theorems}

\subsection{The Nondependent Function Type}
If
\[ \prov \Gamma \rctx \qquad \Gamma^\ominus \prov A : \rtype \qquad \Gamma^\ominus \prov B : \rtype \qquad
\Gamma, \star \prov f : A \to B\]
then there exists an explicit isomorphism
\[\Gamma \prov \pp f {A \to B}  \cong (a :  A) (a' : \pp { a} A) \to \pp {f\ a} B \]
Explicitly, here is the construction:
\[ \Gamma \prov \mathsf{fore} : (f' : \pp f {A \to B}) (a :  A) (a' : \pp { a} A) \to \pp {f\ a} B \]
\[\mathsf{fore} = \lambda f'.\lambda a.\lambda a'.  \{(\epair f {f'})\ (\epair { a} {a'})\}\]
\[ \Gamma \prov \mathsf{back} : (k : (a :  A) (a' : \pp { a} A) \to \pp {f\ a} B) \to \pp f {A \to B} \]
\[\mathsf{back} = \lambda k. \{\lambda x . (\epair {f\ x} {k\ x\ \{x\}})\}\]
Let's typecheck these. Make some abbreviations
\[\Gamma_1 = (\Gamma^\ominus, f' \div \pp f {A \to B}, a \div  A, a' \div \pp { a} A) \]
\[\Gamma_2 = ( \Gamma^\ominus, k \div (a :  A) (a' : \pp { a} A) \to \pp {f\ a} B)\]
\[\Gamma_3 = (\Gamma_2, x :: \wid A, \star)\]
and see
\[
\begin{prooftree}
\[
\[
\[
\justifies
\Gamma_1, \star \prov f  :  A \to B
\]
\[
\justifies
\Gamma_1, \star \prov f' :  \pp f {A \to B}
\]
\justifies
\Gamma_1 \prov \epair f {f'} :  A \to B
\]
\[
\[
\justifies
\Gamma_1, \star \prov { a}  :  A
\]
\[
\justifies
\Gamma_1, \star \prov a' :  \pp { a} A
\]
\justifies
\Gamma_1 \prov \epair { a} {a'} :  A
\]
\justifies
\Gamma_1 \prov (\epair f {f'})\ (\epair { a} {a'}) :  B
\]
\justifies
\Gamma, f' : \pp f {A \to B}, a :  A, a' : \pp { a} A \prov \{(\epair f {f'})\ (\epair { a} {a'})\} : \pp {f\ a} B
\end{prooftree}
\]
checking as a side condition that
\[ (\epair f {f'})\ (\epair { a} {a'})\equiv_\star f\ a\]
and then
\[
\begin{prooftree}
\[
\[
\justifies
\Gamma_3 \prov  k : (a :  A) (a' : \pp { a} A) \to \pp {f\ a} B
\]
\[
\justifies
\Gamma_3 \prov  x : \wid A
