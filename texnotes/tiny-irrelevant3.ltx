\Gamma_3 \prov  x :  A
\]
\justifies
\Gamma_3 \prov  {\{x\}} : \pp x A
\]
\justifies
\Gamma_3 \prov  {k\ x\ \{x\}} : \pp {f\ x} B
\end{prooftree}
\]
can be inserted into
\[
\begin{prooftree}
\[
\[
\[
\[
\justifies
\Gamma_2, x : \wid A, \star \prov f : A \to B
\]
\[
\justifies
\Gamma_2, x : \wid A, \star \prov x : \wid A
\]
\justifies
\Gamma_2, x : \wid A, \star \prov f\ x : B
\]
\qquad
