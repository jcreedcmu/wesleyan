\section{Syntactic Operations}
\subsection{Erasure}
Erasure $|\dash|$ takes a wide type or term and turns it into a narrow type or term.

\[
\begin{tabular}{rcl@{\qquad}l}
$\erase{(x : \wid A) \to \wid B}$&$=$&$(x : \erase{\wid A}) \to \erase{\wid B}$\\
$\erase{(x : \wid A) \x \wid B}$&$=$&$(x : \erase{\wid A}) \x \erase{\wid B}$\\
$\erase{\lambda x.\wid M}$&$=$&$\lambda x.\erase{\wid M}$\\
 $\erase{\wid M\ \wid N} $&$=$&$ \erase{\wid M}\ \erase{\wid N}$\\
$\erase x$&$=$&$x$ \\
$\erase{\gg(x : \nar A).\nar B}$&$=$&$\nar A$\\
$\erase{\bglue(\nar M, \nar N)}$&$=$&$\nar M$\\
$\erase{\epair{\nar M}{\nar N}}$&$=$&$\nar M$\\
$\erase{\wid\rtype}$&$=$&$\nar \rtype$\\
\end{tabular}
\]


\subsection{Inclusion}
Narrow contexts are a subset of wide contexts. We write $\ups$ for the explicit inclusion of narrow contexts into wide contexts.
\[
\begin{tabular}{rcl}
 $ \ups(\nar\Gamma, x :: \wid A)$&$:=$&$(\ups\nar\Gamma, x :: \wid A)$\\
 $ \ups(\nar\Gamma, x \div \nar A)$&$:=$&$(\ups\nar\Gamma, x \div \nar A)$\\
 $ \ups(\cdot)$&$:=$&$\cdot$\\
\end{tabular}\]

\subsection{Promotion and Demotion}

We define operations $\promote\dash$ and $\demote\dash$, both of which take a wide context to a narrow context.
Demotion turns normal variables into weak variables and leaves other variables alone.
Promotion turns normal variables into strong variables and leaves other variables alone.

\[\begin{tabular}{rcl}
 $ \promote{(\wid\Gamma, x : \wid A)}$&$:=$&$(\promote{\wid\Gamma}, x :: \wid A)$\\
 $ \promote{(\wid\Gamma, x :: \wid A)}$&$:=$&$(\promote{\wid\Gamma}, x :: \wid A)$\\
 $ \promote{(\wid\Gamma, x \div \nar A)}$&$:=$&$(\promote{\wid\Gamma}, x \div \nar A)$\\
 $ \promote{(\cdot)}$&$:=$&$\cdot$\\
\end{tabular}
\qquad
\begin{tabular}{rcl}
 $ \demote{(\wid\Gamma, x : \wid A)}$&$:=$&$(\demote{\wid\Gamma}, x \div \erase{\wid A})$\\
 $ \demote{(\wid\Gamma, x :: \wid A)}$&$:=$&$(\demote{\wid\Gamma}, x :: \wid A)$\\
 $ \demote{(\wid\Gamma, x \div \nar A)}$&$:=$&$(\demote{\wid\Gamma}, x \div \nar A)$\\
 $ \demote{(\cdot)}$&$:=$&$\cdot$\\
\end{tabular}\]

As abbreviations, we define
\[\rdemote {\wid A} = \ups(\demote {\wid A}) \qquad \rpromote {\wid A} = \ups(\promote {\wid A})\]


\section{Typing Rules}

\subsection{Context Formation}

\[
\begin{prooftree}
\justifies
\wprov \cdot \rctx
\end{prooftree}
\qquad
\begin{prooftree}
\justifies
\nprov \cdot \rctx
\end{prooftree}
\qquad
\begin{prooftree}
\wprov {\wid\Gamma} \rctx \qquad {\wid\Gamma} \wprov \wid A : \rtype
\justifies
\wprov ({\wid\Gamma}, x : \wid A)\rctx
\end{prooftree}
\]
\[
\begin{prooftree}
\wprov {\wid\Gamma} \rctx \qquad \demote {\wid \Gamma} \nprov \nar A : \rtype
\justifies
\wprov ({\wid\Gamma}, x \div \nar A)\rctx
\end{prooftree}
\qquad
\begin{prooftree}
\wprov {\wid\Gamma} \rctx \qquad \rdemote{\wid\Gamma} \wprov \wid A : \rtype
\justifies
\wprov ({\wid\Gamma}, x :: \wid A)\rctx
\end{prooftree}
\]


\[
\begin{prooftree}
\nprov {\nar\Gamma} \rctx \qquad {\nar\Gamma} \nprov \nar A : \rtype
\justifies
\nprov ({\nar\Gamma}, x \div \nar A)\rctx
\end{prooftree}
\qquad
\begin{prooftree}
\nprov {\nar\Gamma} \rctx \qquad \ups {\nar\Gamma} \wprov \wid A : \rtype
\justifies
\nprov ({\nar\Gamma}, x :: \wid A)\rctx
\end{prooftree}
\]

\subsection{Variable Rules}

\[
\begin{prooftree}
x : \wid A \in  \wid\Gamma
\justifies
\wid\Gamma \wprov x : \wid A
\end{prooftree}
\qquad
\begin{prooftree}
x :: \wid A \in  \wid\Gamma
\justifies
\wid\Gamma \wprov x : \wid A
\end{prooftree}
\]
\[
\begin{prooftree}
x \div \nar A \in  \nar\Gamma
\justifies
\nar\Gamma \nprov x : \nar A
\end{prooftree}
\qquad
\begin{prooftree}
x :: \wid A \in  \nar\Gamma
\justifies
\nar\Gamma \nprov x :  \erase {\wid A}
\end{prooftree}
\]

\subsection{The Fiber Type}
\[
\begin{prooftree}
\ups\nar \Gamma \wprov \wid A : \wid\rtype \quad \nar \Gamma \nprov \nar M : \erase {\wid A}
\justifies
\nar \Gamma \nprov \pp {\nar M} {\wid A} : \nar\rtype
\end{prooftree}
\qquad
\begin{prooftree}
\ups {\nar \Gamma} \wprov \wid M : \wid A
\justifies
\nar \Gamma \nprov \{\wid M\} : \pp  {\erase{\wid M}} {\wid A}
\end{prooftree}
\qquad
\begin{prooftree}
\demote{\wid\Gamma} \nprov \nar M : \erase{\wid A} \quad
\promote{\wid\Gamma} \nprov \nar N : \pp{\nar M}{\wid A}
\justifies
\wid\Gamma \wprov \epair{\nar M}{\nar N} : \wid A
\end{prooftree}
\]
%% In the elimination rule, $\wid A$ is a type over $\wid\Gamma$; the second premise
%% is well-formed because we can transport $\wid A$ to $\rpromote{\wid\Gamma}$ by
%% Lemma~\ref{promotion.weakening} and transport $\nar M$ to $\promote{\wid\Gamma}$ by Lemma~\ref{narrow.weakening}.

\subsubsection{Definitional Equality}

Fiber type definitional equality works like this. If $\nar \Gamma \nprov \nar N : \pp{\nar M}{\wid A}$ then
\[
  \nar N \equiv_\eta \{\epair{\nar M}{\nar N}\}
\]
and in general
\[
\epair{\nar M}{\{\wid N\}} \equiv_\beta \wid N
\]


\subsection{The Glue Type}
\[
\begin{prooftree}
\demote{\wid\Gamma} \nprov \nar A : \nar\rtype \qquad
\promote{\wid\Gamma}, x \div \nar A \nprov \nar B : \nar\rtype
\justifies
\wid\Gamma \wprov \gg(x : \nar A).\nar B : \wid\rtype
\end{prooftree}
\qquad
\begin{prooftree}
\demote{\wid\Gamma} \nprov \nar M : \nar A \qquad
\promote{\wid\Gamma} \nprov \nar N : [\nar M/_{\div}x]\nar B
\justifies
\wid\Gamma \wprov \bglue(\nar M, \nar N) : \gg(x : \nar A).\nar B
\end{prooftree}
\]
\[
\begin{prooftree}
\ups\nar\Gamma \wprov \wid M : \gg(x : \nar A).\nar B
\justifies
\nar\Gamma \nprov \bunglue \wid M : [\erase{\wid M}/_{\div}x]\nar B
\end{prooftree}
\]

\subsubsection{Definitional Equality}
Definitional equality works like this. If $\wid \Gamma \wprov \wid M : \gg(x : \nar A) . \nar B$ then
\[
 \wid M \equiv_\eta \bglue(\erase{\wid M}, \bunglue \wid M)
\]
and in general
\[
\bunglue(\bglue(\nar M,\nar N)) \equiv_\beta \nar N
\]

\section{Better Substitution}
\def\wsub#1{[#1]_{\wid \bullet}}
\def\nsub#1{[#1]_{\nar \bullet}}

We make definitions like
\[\nsub{\wid P/x} \pp{\nar M}{\wid A} = \pp{\wsub{\wid P/x}\nar M} {\wsub{\wid P/x}\wid A}\]
\[\wsub{\wid P/x} (\epair{\nar M}{\nar N}) = \epair{\nsub{\erase{\wid P}/x}\nar M}{\nsub{\wid P/x}\nar N}\]

\begin{lemma}
\[\nsub{\erase{\wid P}/x}\erase{\wid A}  = \erase{\wsub{\wid P/x}\wid A} \]
\end{lemma}



\begin{theorem}[Substitution Theorem]\ %
  \begin{enumerate}
  \item $\wid \Gamma \wprov \wid M : \wid A$ and $\wid \Gamma, x : \wid A \wprov  \wid J$, then $\wid \Gamma \wprov \wsub{\wid M/x}\wid J$.
  \item $\demote{\wid \Gamma} \nprov \nar M : \nar A$ and $\wid \Gamma, x \div \nar A \wprov  \wid J$,
then $\wid \Gamma \wprov \wsub{\nar M/x}\wid J$.
  \item $\rdemote{\wid \Gamma} \wprov \wid M : \wid A$ and $\wid \Gamma, x :: \wid A \wprov  \wid J$,
then $\wid \Gamma \wprov \wsub{\wid M/x}\wid J$.
  \item ${\nar \Gamma} \nprov \nar M : \nar A$ and $\nar \Gamma, x \div \nar A \nprov  \nar J$,
then $\nar \Gamma \nprov \nsub{\nar M/x}\nar J$.
  \item $\ups{\nar \Gamma} \wprov \wid M : \wid A$ and $\nar \Gamma, x :: \wid A \nprov  \nar J$,
then $\nar \Gamma \nprov \nsub{\wid M/x}\nar J$.
  \end{enumerate}
\end{theorem}

\begin{proof}\ %
  \begin{itemize}
  \item
\[\begin{prooftree}
\ups\nar \Gamma, x :: \wid B \wprov \wid A : \wid\rtype \quad \nar \Gamma, x :: \wid B \nprov \nar M : \erase {\wid A}
\justifies
\nar \Gamma, x :: \wid B \nprov \pp {\nar M} {\wid A} : \nar\rtype
\end{prooftree}\]
I.h. gives us
\[\ups\nar \Gamma \wprov \wsub{\wid P/x} \wid A : \wid\rtype \quad \nar \Gamma \nprov \nsub{\wid P/x}\nar M : \nsub{\wid P/x}\erase {\wid A}\]
so we derive (using previous lemma)
\[\begin{prooftree}
\ups\nar \Gamma \wprov \wsub{\wid P/x} \wid A : \wid\rtype \quad \nar \Gamma \nprov \nsub{\wid P/x}\nar M : \erase {\wsub{\wid P/x} \wid A}
\justifies
\nar \Gamma \nprov \pp {\nsub{\wid P/x}\nar M} {\wsub{\wid P/x} \wid A} : \nar\rtype
\end{prooftree}\]


\item
\[\begin{prooftree}
\demote{\wid\Gamma}, x \div \erase{\wid B} \nprov \nar M : \erase{\wid A} \quad
\promote{\wid\Gamma}, x :: \wid B \nprov \nar N : \pp{\nar M}{\wid A}
\justifies
\wid\Gamma, x : \wid B \wprov \epair{\nar M}{\nar N} : \wid A
\end{prooftree}\]
We suppose $\wid \Gamma \prov \wid P : \wid B$. Therefore
We suppose $\demote{\wid \Gamma} \prov \erase{\wid P} : \erase{\wid B}$ by some lemma,
and $\promote{\wid \Gamma} \prov \wid P : \wid B$ by weakening. Therefore
By i.h. we have
\[\demote{\wid\Gamma} \nprov  \nsub{\erase{\wid P}/x}\nar M :  \nsub{\erase{\wid P}/x}\erase{\wid A} \qquad
\promote{\wid\Gamma} \nprov \nsub{\wid P/x} \nar N : \nsub{\wid P/x} \pp{\nar M}{\wid A}\]

Now we want to derive
\[\begin{prooftree}
\demote{\wid\Gamma} \nprov \nsub{\erase{\wid P}/x}\nar M : \erase{\wsub{\wid P/x}\wid A} \quad
\promote{\wid\Gamma} \nprov \nsub{\wid P/x}\nar  N : \pp{\nsub{\erase{\wid P}/x}\nar M}{\wsub{\wid P/x}\wid A}
\justifies
\wid\Gamma \wprov \epair{\nsub{\erase{\wid P}/x}\nar M}{\nsub{\wid P/x}\nar N} : \wsub{\wid P/x}\wid A
\end{prooftree}\]
But to do this we must see
\[\nsub{\wid P/x} \pp{\nar M}{\wid A} = \pp{\nsub{\erase{\wid P}/x}\nar M}{\wsub{\wid P/x}\wid A}\]
We \textcolor{red}{XXX NEED SOME KIND OF LEMMA} to show us that since
\[\demote{\wid\Gamma}, x \div \erase{\wid B} \nprov \nar M : \erase{\wid A} \]
we can infer
\[\nsub{\erase{\wid P}/x}\nar M \equiv \nsub{\wid P/x}\nar M\]

  \end{itemize}
\end{proof}




\section{Substitution}
\subsection{Typing of Substitutions}

\[
\begin{prooftree}
\wid \Gamma \wprov \wid M : \wid A
\justifies
\wid \Gamma \wprov [\wid M/ x] : (\wid \Gamma, x : \wid A)
\end{prooftree}
\]
\[
\begin{prooftree}
\demote{\wid \Gamma} \nprov \nar M : \nar A
\justifies
\wid \Gamma \wprov [\nar M/_{\div} x] : (\wid \Gamma, x \div \nar A)
\end{prooftree}
\qquad
\begin{prooftree}
\rdemote{\wid \Gamma} \wprov \wid M : \wid A
\justifies
\wid \Gamma \wprov [\wid M/_{::} x] : (\wid \Gamma, x :: \wid A)
\end{prooftree}
\]
\[
\begin{prooftree}
\nar \Gamma \nprov \nar M : \nar A
\justifies
\nar \Gamma \nprov [\nar M/_{\div} x] : (\nar \Gamma, x \div \nar A)
\end{prooftree}
\qquad
\begin{prooftree}
\ups \nar \Gamma \wprov \wid M : \wid A
\justifies
\nar \Gamma \nprov [\wid M/_{::} x] : (\nar \Gamma, x :: \wid A)
\end{prooftree}
\]
\subsection{Promotion, Demotion, Inclusion on Substitutions}
\[\begin{array}{rcl}
  \demote{[\wid M/x]} &=& [\erase{\wid M}/_{\div} x]\\
  \demote{[\nar M/_{\div} x]} &=& [{\nar M}/_{\div} x]\\
  \demote{[\wid M/_{::} x]} &=& [{\wid M}/_{::} x]\\
\end{array}
\qquad
\begin{array}{rcl}
  \promote{[\wid M/x]} &=& [{\wid M}/_{::} x]\\
  \promote{[\nar M/_{\div} x]} &=& [{\nar M}/_{\div} x]\\
  \promote{[\wid M/_{::} x]} &=& [{\wid M}/_{::} x]\\
\end{array}
\qquad
\begin{array}{rcl}
  \ups{[\nar M/_{\div} x]} &=& [{\nar M}/_{\div} x]\\
  \ups{[\wid M/_{::} x]} &=& [{\wid M}/_{::} x]\\
\end{array}
\]
\subsection{Substitution on Contexts}

\[
\begin{array}{rcl}
  \wid\theta (\wid \Gamma, x : \wid A) &=&   (\wid\theta\wid \Gamma, x : \wid\theta\wid A)\\
  \wid\theta (\wid \Gamma, x \div \nar A) &=&   (\wid\theta\wid \Gamma, x : \demote{\wid\theta}\nar A)\\
  \wid\theta (\wid \Gamma, x :: \wid A) &=&   (\wid\theta\wid \Gamma, x :: \rdemote{\wid\theta}\wid A)\\
  \nar\theta (\nar \Gamma, x \div \nar A) &=&   (\nar\theta\nar \Gamma, x : {\nar\theta}\nar A)\\
  \nar\theta (\nar \Gamma, x :: \wid A) &=&   (\nar\theta\nar \Gamma, x :: (\ups{\nar\theta})\wid A)\\

\end{array}
\]



\section{Metatheory}
\begin{lemma}
\label{erase.type}
If $\wid \Gamma \wprov \wid A : \rtype$, then
 $\demote{\wid \Gamma} \nprov \erase{\wid A} : \rtype$.
\end{lemma}

\begin{lemma}
\label{erase.term}
If $\wid \Gamma \wprov \wid M : \wid A$, then
 $\demote{\wid \Gamma} \nprov \erase{\wid M} : \erase{\wid A} $.
\end{lemma}




\begin{lemma}
\label{include.pres}
If $\nprov \nar \Gamma \rctx$, then
$\wprov \ups{\nar \Gamma} \rctx$.
\end{lemma}

\begin{proof}\ %
  \begin{itemize}
  \item
If we have
\[
\begin{prooftree}
\nprov {\nar\Gamma} \rctx \qquad {\nar\Gamma} \nprov \nar A : \rtype
\justifies
\nprov ({\nar\Gamma}, x \div \nar A)\rctx
\end{prooftree}
\]
then we construct (using Lemma~\ref{include.demote.eq.orig})
\[
\begin{prooftree}
\wprov {\ups\nar\Gamma} \rctx \qquad \demote {(\ups\nar\Gamma)} \nprov \nar A : \rtype
\justifies
\wprov ({\ups\nar\Gamma}, x \div \nar A)\rctx
\end{prooftree}
\]
  \item
If we have
\[
\begin{prooftree}
\nprov {\nar\Gamma} \rctx \qquad \ups {\nar\Gamma} \wprov \wid A : \rtype
\justifies
\nprov ({\nar\Gamma}, x :: \wid A)\rctx
\end{prooftree}
\]
then we construct (using Lemma~\ref{include.demote.eq.orig})
\[
\begin{prooftree}
\wprov {\ups\nar\Gamma} \rctx \qquad \rdemote{(\ups\nar\Gamma)} \wprov \wid A : \rtype
\justifies
\wprov ({\ups\nar\Gamma}, x :: \wid A)\rctx
\end{prooftree}
\]
  \end{itemize}
\cqed
\end{proof}


\begin{lemma}[Demotion Weakening]
\label{demotion.weakening}
If $\rdemote{\wid\Gamma} \wprov J$, then $\wid \Gamma \wprov J$.
\end{lemma}

\begin{lemma}[Promotion Weakening]
\label{promotion.weakening}
If $\wid\Gamma \wprov J$, then $\rpromote{\wid\Gamma} \wprov J$.
\end{lemma}

\begin{lemma}[Narrow Weakening]
\label{narrow.weakening}
If $\demote{\wid\Gamma} \nprov J$, then $\promote{\wid\Gamma} \nprov J$.
\end{lemma}

\begin{lemma}
\label{include.demote.eq.orig}
$\demote{(\ups\nar\Gamma)} = \nar\Gamma$ and
$\demote{(\ups\nar\theta)} = \nar\theta$.
\end{lemma}

\begin{lemma}
\label{include.promote.eq.orig}
$\promote{(\ups\nar\Gamma)} = \nar\Gamma$ and
$\promote{(\ups\nar\theta)} = \nar\theta$.
\end{lemma}


\begin{lemma}
\label{demote.pres}
If $\wprov \wid \Gamma \rctx$, then
$\nprov \demote{\wid \Gamma} \rctx$.
\end{lemma}
\begin{proof}\ %
  \begin{itemize}
  \item If we have
\[
\begin{prooftree}
\wprov {\wid\Gamma} \rctx \qquad {\wid\Gamma} \wprov \wid A : \rtype
\justifies
\wprov ({\wid\Gamma}, x : \wid A)\rctx
\end{prooftree}
\]
then we construct (using Lemma~\ref{erase.type})
\[
\begin{prooftree}
\nprov {\demote{\wid\Gamma}} \rctx \qquad {\demote{\wid\Gamma}} \nprov \erase{\wid A} : \rtype
\justifies
\nprov ({\demote{\wid\Gamma}}, x \div \erase{\wid A})\rctx
\end{prooftree}
\]
  \item If we have
\[
\begin{prooftree}
\wprov {\wid\Gamma} \rctx \qquad \demote {\wid \Gamma} \nprov \nar A : \rtype
\justifies
\wprov ({\wid\Gamma}, x \div \nar A)\rctx
\end{prooftree}
\]
then we construct
\[
\begin{prooftree}
\nprov {\demote{\wid\Gamma}} \rctx \qquad {\demote{\wid\Gamma}} \nprov \nar A : \rtype
\justifies
\nprov ({\demote{\wid\Gamma}}, x \div \nar A)\rctx
\end{prooftree}
\]
  \item If we have
\[
\begin{prooftree}
\wprov {\wid\Gamma} \rctx \qquad \rdemote{\wid\Gamma} \wprov \wid A : \rtype
\justifies
\wprov ({\wid\Gamma}, x :: \wid A)\rctx
\end{prooftree}
\]
then we construct
\[
\begin{prooftree}
\nprov {\demote{\wid\Gamma}} \rctx \qquad \rdemote{\wid\Gamma} \wprov \wid A : \rtype
\justifies
\nprov ({\demote{\wid\Gamma}}, x :: \wid A)\rctx
\end{prooftree}
\]
  \end{itemize}
  \cqed
\end{proof}

\begin{lemma}
\label{promote.pres}
If $\wprov \wid \Gamma \rctx$, then
$\nprov \promote{\wid \Gamma} \rctx$.
\end{lemma}
\begin{proof}\ %
  \begin{itemize}
  \item If we have
\[
\begin{prooftree}
\wprov {\wid\Gamma} \rctx \qquad {\wid\Gamma} \wprov \wid A : \rtype
\justifies
\wprov ({\wid\Gamma}, x : \wid A)\rctx
\end{prooftree}
\]
then we construct (using Lemma~\ref{promotion.weakening})
\[
\begin{prooftree}
\nprov {\promote{\wid\Gamma}} \rctx \qquad \rpromote{\wid \Gamma} \wprov \wid A : \rtype
\justifies
\nprov ({\promote{\wid\Gamma}}, x :: \wid A)\rctx
\end{prooftree}
\]
  \item If we have
\[
\begin{prooftree}
\wprov {\wid\Gamma} \rctx \qquad \demote {\wid \Gamma} \nprov \nar A : \rtype
\justifies
\wprov ({\wid\Gamma}, x \div \nar A)\rctx
\end{prooftree}
\]
then we construct (using Lemma~\ref{narrow.weakening})
\[
\begin{prooftree}
\nprov {\promote{\wid\Gamma}} \rctx \qquad {\promote{\wid\Gamma}} \nprov \nar A : \rtype
\justifies
\nprov ({\promote{\wid\Gamma}}, x \div \nar A)\rctx
\end{prooftree}
\]
  \item If we have
\[
\begin{prooftree}
\wprov {\wid\Gamma} \rctx \qquad \rdemote{\wid\Gamma} \wprov \wid A : \rtype
\justifies
\wprov ({\wid\Gamma}, x :: \wid A)\rctx
\end{prooftree}
\]
then we construct (using Lemmas~\ref{demotion.weakening} and~\ref{promotion.weakening})
\[
\begin{prooftree}
\nprov {\promote{\wid\Gamma}} \rctx \qquad \rpromote{\wid\Gamma} \wprov \wid A : \rtype
\justifies
\nprov ({\promote{\wid\Gamma}}, x :: \wid A)\rctx
\end{prooftree}
\]
  \end{itemize}
  \cqed
\end{proof}








