\subsection{Substitution}


\begin{lemma}\ %
\label{substitution.modification}
  \begin{enumerate}
  \item If $\wid \Gamma \wprov \wid \theta : \wid \Delta$, then $\demote{\wid \Gamma} \nprov \demote{\wid \theta} : \demote{\wid \Delta}$.
  \item If $\wid \Gamma \wprov \wid \theta : \wid \Delta$, then $\promote{\wid \Gamma} \nprov \promote{\wid \theta} : \promote{\wid \Delta}$.
  \item If $\nar \Gamma \nprov \nar \theta : \nar \Delta$, then $\ups{\nar \Gamma} \wprov \ups{\nar \theta} : \ups{\nar \Delta}$.
  \end{enumerate}
\end{lemma}

\begin{proof}\ %
  \begin{itemize}
  \item Case of demotion of ordinary variable. Use
Lemma~\ref{erase.term} to do
\[
\begin{prooftree}
\wid \Gamma \wprov \wid M : \wid A
\justifies
\wid \Gamma \wprov [\wid M/ x] : (\wid \Gamma, x : \wid A)
\end{prooftree}
\quad\mapsto\quad
\begin{prooftree}
\demote{\wid \Gamma} \wprov \erase{\wid M} : \erase{\wid A}
\justifies
\demote{\wid \Gamma} \nprov [|\wid M|/_{\div} x] : (\demote{\wid \Gamma}, x \div |\wid A|)
\end{prooftree}
\]
  \item Case of promotion of ordinary variable. Use
Lemma~\ref{promotion.weakening} to do
\[
\begin{prooftree}
\wid \Gamma \wprov \wid M : \wid A
\justifies
\wid \Gamma \wprov [\wid M/ x] : (\wid \Gamma, x : \wid A)
\end{prooftree}
\quad\mapsto\quad
\begin{prooftree}
\ups (\promote{\wid \Gamma}) \wprov \wid M : \wid A
\justifies
\promote{\wid \Gamma} \nprov [\wid M/_{::} x] : (\promote{\wid \Gamma}, x :: \wid A)
\end{prooftree}
\]
  \item Case of demotion of weak variable. Simply do
\[
\begin{prooftree}
\demote{\wid \Gamma} \nprov \nar M : \nar A
\justifies
\wid \Gamma \wprov [\nar M/_{\div} x] : (\wid \Gamma, x \div \nar A)
\end{prooftree}
\quad\mapsto\quad
\begin{prooftree}
\demote{\wid \Gamma} \nprov \nar M : \nar A
\justifies
\demote{\wid \Gamma} \nprov [\nar M/_{\div} x] : (\demote{\wid \Gamma}, x \div \nar A)
\end{prooftree}
\]
  \item Case of promotion of weak variable. Use
Lemma~\ref{narrow.weakening} to do
\[
\begin{prooftree}
\demote{\wid \Gamma} \nprov \nar M : \nar A
\justifies
\wid \Gamma \wprov [\nar M/_{\div} x] : (\wid \Gamma, x \div \nar A)
\end{prooftree}
\quad\mapsto\quad
\begin{prooftree}
\promote{\wid \Gamma} \nprov \nar M : \nar A
\justifies
\promote{\wid \Gamma} \nprov [\nar M/_{\div} x] : (\promote{\wid \Gamma}, x \div \nar A)
\end{prooftree}
\]
  \item Case of demotion of strong variable. Simply do
\[
\begin{prooftree}
\rdemote{\wid \Gamma} \wprov \wid M : \wid A
\justifies
\wid \Gamma \wprov [\wid M/_{::} x] : (\wid \Gamma, x :: \wid A)
\end{prooftree}
\quad\mapsto\quad
\begin{prooftree}
\ups (\demote{\wid \Gamma}) \wprov \wid M : \wid A
\justifies
\demote{\wid \Gamma} \nprov [\wid M/_{::} x] : (\demote{\wid \Gamma}, x :: \wid A)
\end{prooftree}
\]
  \item Case of promotion of strong variable. Use
Lemma~\ref{demotion.weakening} and Lemma~\ref{promotion.weakening} to do
\[
\begin{prooftree}
\rdemote{\wid \Gamma} \wprov \wid M : \wid A
\justifies
\wid \Gamma \wprov [\wid M/_{::} x] : (\wid \Gamma, x :: \wid A)
\end{prooftree}
\quad\mapsto\quad
\begin{prooftree}
\ups (\promote{\wid \Gamma}) \wprov \wid M : \wid A
\justifies
\promote{\wid \Gamma} \nprov [\wid M/_{::} x] : (\promote{\wid \Gamma}, x :: \wid A)
\end{prooftree}
\]
  \item Case of inclusion of weak variable. Use Lemma~\ref{include.demote.eq.orig} to do
\[
\begin{prooftree}
\nar \Gamma \nprov \nar M : \nar A
\justifies
\nar \Gamma \nprov [\nar M/_{\div} x] : (\nar \Gamma, x \div \nar A)
\end{prooftree}
\quad\mapsto\quad
\begin{prooftree}
\demote{(\ups \nar \Gamma)} \nprov \nar M : \nar A
\justifies
\ups \nar \Gamma \wprov [\nar M/_{\div} x] : (\ups \nar \Gamma, x \div \nar A)
\end{prooftree}
\]
  \item Case of inclusion of strong variable. Use Lemma~\ref{include.demote.eq.orig} to do
\[
\begin{prooftree}
\ups \nar \Gamma \wprov \wid M : \wid A
\justifies
\nar \Gamma \nprov [\wid M/_{::} x] : (\nar \Gamma, x :: \wid A)
\end{prooftree}
\quad\mapsto\quad
\begin{prooftree}
\rdemote{(\ups \nar \Gamma)} \wprov \wid M : \wid A
\justifies
\ups \nar \Gamma \wprov [\wid M/_{::} x] : (\ups \nar \Gamma, x :: \wid A)
\end{prooftree}
\]
  \end{itemize}
\cqed
\end{proof}


\begin{lemma}
\label{demotion.erase.compat}
$ \demote{\wid\theta}|\wid A| = \erase{\wid\theta\wid A}$ and $ \demote{\wid\theta}|\wid M| = \erase{\wid\theta\wid M}$.
\end{lemma}

\begin{proof}

\cqed
\end{proof}

\begin{lemma}\ %
\label{operation.substitution.commute}
\begin{itemize}
\item $\demote{\wid\theta}\demote{\wid\Gamma} = \demote{(\wid\theta \wid\Gamma)}$
\item $(\ups {\nar\theta})(\ups {\nar\Gamma}) = \ups{(\nar\theta \nar\Gamma)}$
\end{itemize}

\end{lemma}

\begin{proof}
\textcolor{red}{XXX THIS PROOF NO LONGER VALID}
Case split by how we construct the context.
  \begin{itemize}
  \item $ ({\wid\Gamma}, x : \wid A)$.
Our goal is to show
\[\rdemote{\wid\theta}\rdemote{({\wid\Gamma}, x : \wid A)} = \rdemote{(\wid\theta ({\wid\Gamma}, x : \wid A))}\]
which by definitions and Lemma~\ref{include.demote.eq.orig} is
\[(\rdemote{\wid\theta}\rdemote{\wid\Gamma}, x  \div \demote{\wid\theta}|\wid A|) = (\rdemote{(\wid\theta {\wid\Gamma})}, x \div \erase{\wid\theta\wid A})\]
By induction hypothesis and Lemma~\ref{demotion.erase.compat}, this is so.
\item
$ ({\wid\Gamma}, x \div \nar A)$.
Our goal is to show
\[\rdemote{\wid\theta}\rdemote{({\wid\Gamma}, x \div \nar A)} = \rdemote{(\wid\theta ({\wid\Gamma}, x \div \nar A))}\]
which by definitions and Lemma~\ref{include.demote.eq.orig} is
\[ (\rdemote{\wid\theta}\rdemote{\wid\Gamma}, x \div \demote{\wid\theta}\nar A) = (\rdemote{(\wid \theta {\wid\Gamma})}, x \div \demote{\wid\theta}\nar A)\]
By the induction hypothesis, this is so.
\item $({\wid\Gamma}, x :: \wid A)$.
Our goal is to show
\[\rdemote{\wid\theta}\rdemote{({\wid\Gamma}, x :: \wid A)} = \rdemote{(\wid\theta ({\wid\Gamma}, x :: \wid A))}\]
which by definitions and Lemma~\ref{include.demote.eq.orig} is
\[(\rdemote{\wid\theta}\rdemote{\wid\Gamma}, x :: \rdemote{\wid\theta}\wid A) =  (\rdemote{(\wid\theta{\wid\Gamma})}, x :: \rdemote{\wid\theta}\wid A)\]
By the induction hypothesis, this is so.
  \end{itemize}
\cqed
\end{proof}

\begin{theorem}[Substitution Theorem]\ %
  \begin{enumerate}
  \item If $\wid \Delta \wprov \wid \theta : \wid \Gamma$ and $\wid \Gamma \wprov  \wid J$, then
$\wid \Delta\wprov \wid \theta \wid J$.
  \item If $\nar \Delta \nprov \nar \theta : \nar \Gamma$ and $\nar \Gamma \nprov  \nar J$, then
$\nar \Delta\nprov \nar \theta \nar J$.
  \end{enumerate}
\end{theorem}

\begin{proof}\ %
  \begin{itemize}
\item Consider the case of
\[
\begin{prooftree}
\ups\nar \Gamma \wprov \wid A : \wid\rtype \quad \nar \Gamma \nprov \nar M : \erase {\wid A}
\justifies
\nar \Gamma \nprov \pp {\nar M} {\wid A} : \nar\rtype
\end{prooftree}
\]
We suppose $\nar \Delta \nprov \nar \theta : \nar \Gamma$.
By
Lemma~\ref{substitution.modification} we have
\[\ups{\nar\Delta}  \wprov \ups{\nar\theta} : \ups{\nar\Gamma}\]
Now apply the induction hypothesis to get
\[\ups\nar \Delta \wprov (\ups{\nar\theta})  \wid A : \wid\rtype \qquad \nar \Delta \nprov {\nar\theta} \nar M : \nar \theta \erase {\wid A}\]

Now thanks to Lemmas~\ref{demotion.erase.compat} and~\ref{include.demote.eq.orig}, we can derive
\[
\begin{prooftree}
